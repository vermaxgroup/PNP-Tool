function exportJSON(){
  const d={progs:PROGS,cols:COLS,clients:CLIENTS,results:RESULTS,tabs:TABS,clientFields:CLIENT_EXTRA_FIELDS,metrics:CUSTOM_METRICS,updateLog:UPDATE_LOG,headings:JSON.parse(localStorage.getItem(SK.headings)||'{}'),pgtitle:localStorage.getItem(SK.pgtitle)||'',exported:new Date().toISOString()};
  dl(JSON.stringify(d,null,2),'application/json',`canada_pnp_backup_${new Date().toISOString().split('T')[0]}.json`);
  toast('⬇ Backup downloaded');
}
function exportCSV(){
  const vc=visCols();const hdr=vc.map(c=>'"'+c.lbl+'"').join(',');
  const rows=PROGS.map(p=>vc.map(c=>'"'+String(p[c.key]!==undefined?p[c.key]:'').replace(/"/g,'""')+'"').join(','));
  dl([hdr,...rows].join('\n'),'text/csv',`pnp_programs_${new Date().toISOString().split('T')[0]}.csv`);
  toast('⬇ CSV exported');
}
function dl(content,type,filename){
  const b=new Blob([content],{type});const u=URL.createObjectURL(b);const a=document.createElement('a');a.href=u;a.download=filename;a.click();URL.revokeObjectURL(u);
}
function importJSON(){
  const f=document.getElementById('imp-file').files[0];if(!f)return;
  const reader=new FileReader();
  reader.onload=e=>{
    try{
      const d=JSON.parse(e.target.result);
      if(d.progs&&Array.isArray(d.progs)){
        showConfirm(`Import ${d.progs.length} programs?`,'This will REPLACE all current programs, clients, and results.',()=>{
          PROGS=d.progs;if(d.cols)COLS=d.cols;if(d.clients)CLIENTS=d.clients;if(d.results)RESULTS=d.results;
          if(d.tabs)TABS=d.tabs;if(d.clientFields)CLIENT_EXTRA_FIELDS=d.clientFields;
          if(d.metrics)CUSTOM_METRICS=d.metrics;if(d.updateLog)UPDATE_LOG=d.updateLog;
          if(d.headings){localStorage.setItem(SK.headings,JSON.stringify(d.headings));}
          if(d.pgtitle){localStorage.setItem(SK.pgtitle,d.pgtitle);document.getElementById('page-title-tag').textContent=d.pgtitle;}
          saveAll('Data imported');closeM('data-modal');init();toast(`✅ Imported ${PROGS.length} programs, ${CLIENTS.length} clients`);
        });
      }else toast('⚠ Invalid JSON format');
    }catch{toast('⚠ Could not read file');}
  };reader.readAsText(f);
}
function confirmReset(){
  showConfirm('Reset programs to original data?','Programs will be restored to defaults. Clients and results are kept. Custom tabs, fields, and metrics are kept.',()=>{
    PROGS=cloneDefault();COLS=JSON.parse(JSON.stringify(BASE_COLS));
    saveAll('Programs reset');closeM('data-modal');renderTabs();showTab(_activeTabId||'dashboard');toast('↺ Programs reset to defaults');
  });
}

