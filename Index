let CALC_CFG = null;
function loadCalcCfg(){
  try{
    const saved = JSON.parse(localStorage.getItem(SK_CALC_CFG));
    const def = getDefaultCalcCfg();
    if(saved){
      // Deep merge — preserve defaults for any missing keys
      CALC_CFG = saved;
      if(!CALC_CFG.crs) CALC_CFG.crs = def.crs;
      if(!CALC_CFG.fsw) CALC_CFG.fsw = def.fsw;
      if(!CALC_CFG.crs.labels) CALC_CFG.crs.labels = def.crs.labels;
      if(!CALC_CFG.fsw.labels) CALC_CFG.fsw.labels = def.fsw.labels;
      // Merge any missing label keys
      Object.entries(def.crs.labels).forEach(([k,v])=>{ if(!CALC_CFG.crs.labels[k]) CALC_CFG.crs.labels[k]=v; });
      Object.entries(def.fsw.labels).forEach(([k,v])=>{ if(!CALC_CFG.fsw.labels[k]) CALC_CFG.fsw.labels[k]=v; });
      if(!CALC_CFG.fsw.ageOpts) CALC_CFG.fsw.ageOpts = def.fsw.ageOpts;
      if(!CALC_CFG.fsw.eduOpts) CALC_CFG.fsw.eduOpts = def.fsw.eduOpts;
      if(!CALC_CFG.fsw.workOpts) CALC_CFG.fsw.workOpts = def.fsw.workOpts;
    } else {
      CALC_CFG = def;
    }
  } catch{ CALC_CFG = getDefaultCalcCfg(); }
}
function saveCalcCfg(){ localStorage.setItem(SK_CALC_CFG, JSON.stringify(CALC_CFG)); }
function getCfgLabel(calc, key){ return (CALC_CFG&&CALC_CFG[calc]&&CALC_CFG[calc].labels&&CALC_CFG[calc].labels[key]) || key; }

// ── INLINE LABEL EDITING — double-click any label in Edit Mode ──
function editCalcLabel(calc, key, el){
  if(!editMode) return;
  el.contentEditable='true';
  el.style.outline='2px dashed var(--amber)';
  el.style.borderRadius='3px';
  el.style.minWidth='30px';
  el.focus();
  const save=()=>{
    el.contentEditable='false';
    el.style.outline='';
    const val=(el.textContent||'').trim();
    if(!CALC_CFG) loadCalcCfg();
    if(!CALC_CFG[calc].labels) CALC_CFG[calc].labels={};
    CALC_CFG[calc].labels[key]=val||getCfgLabel(calc,key);
    saveCalcCfg();
    toast('Label saved');
  };
  el.onblur=save;
  el.onkeydown=e=>{ if(e.key==='Enter'){e.preventDefault();el.blur();} if(e.key==='Escape'){el.textContent=getCfgLabel(calc,key);el.blur();} };
}
// Helper: wrap a label in an editable span
function lbl(calc, key, extraStyle){
  const text = getCfgLabel(calc, key);
  const style = extraStyle||'';
  const clickAttr = `ondblclick="if(editMode)editCalcLabel('${calc}','${key}',this)" title="${editMode?'Double-click to edit label':''}"`;
  return `<span data-calclabel="${calc}-${key}" style="${style}cursor:${editMode?'text':'default'}" ${clickAttr}>${esc(text)}</span>`;
}

