<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title id="page-title-tag">Canada PNP Tool</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --navy:#1a3f6f;--red:#c0392b;--blue:#1a5fa8;--green:#276221;
  --amber:#92560a;--bg:#f4f4f0;--white:#fff;--border:#ddddd5;
  --text:#1a1a1a;--muted:#666;--light:#f8f8f5;--teal:#0d6e6e;
  /* Theme overrides — set by JS */
  --theme-primary:var(--navy);--theme-accent:var(--blue);--theme-bg:var(--bg);
}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,sans-serif;font-size:14px;color:var(--text);background:var(--bg);line-height:1.5}
a{color:var(--blue);text-decoration:none}a:hover{text-decoration:underline}
.nav{background:var(--white);border-bottom:1.5px solid var(--border);padding:0 16px;display:flex;align-items:center;position:sticky;top:0;z-index:300;flex-wrap:wrap;min-height:48px}
.nav-brand{display:flex;align-items:center;gap:8px;margin-right:12px;flex-shrink:0}
.nav-brand-text{font-size:13px;font-weight:800;color:var(--navy);letter-spacing:-.3px;white-space:nowrap;cursor:pointer;border-radius:4px;padding:4px 6px;transition:background .12s}
.nav-brand-text:hover{background:#fff3e0}
.nav-brand-text[contenteditable=true]{outline:2px solid var(--amber);background:#fffde7}
.nav-tabs{display:flex;flex:1;overflow-x:auto;gap:0}
.nav-tab{padding:12px 11px;font-size:12px;color:var(--muted);cursor:pointer;border-bottom:2px solid transparent;white-space:nowrap;transition:all .12s;user-select:none;flex-shrink:0}
.nav-tab:hover{color:var(--text);background:var(--light)}
.nav-tab.active{color:var(--blue);border-bottom-color:var(--blue);font-weight:700}
.nav-tab .tlbl[contenteditable=true]{outline:2px solid var(--amber);background:#fffde7;border-radius:3px;cursor:text;padding:1px 3px}
.nav-right{display:flex;align-items:center;gap:7px;padding:6px 0;flex-shrink:0;margin-left:8px}
.etoggle{display:flex;align-items:center;gap:6px;padding:5px 11px;border-radius:6px;border:1.5px solid var(--border);background:var(--white);cursor:pointer;font-size:12px;font-weight:600;color:var(--muted);transition:all .12s;user-select:none}
.etoggle:hover,.etoggle.on{border-color:var(--amber);color:var(--amber);background:#fff8e1}
.edot{width:7px;height:7px;border-radius:50%;background:#ccc;transition:background .12s}
.etoggle.on .edot{background:var(--amber)}
.btn{display:inline-flex;align-items:center;gap:5px;padding:6px 12px;border-radius:6px;font-size:12px;font-weight:600;cursor:pointer;border:1px solid;transition:all .12s;font-family:inherit;white-space:nowrap}
.btn-primary{background:var(--navy);color:#fff;border-color:var(--navy)}.btn-primary:hover{background:#0f2a4a}
.btn-blue{background:var(--blue);color:#fff;border-color:var(--blue)}.btn-blue:hover{background:#134d8a}
.btn-sec{background:var(--white);color:var(--text);border-color:#bbb}.btn-sec:hover{background:var(--bg)}
.btn-success{background:var(--green);color:#fff;border-color:var(--green)}.btn-success:hover{background:#1c511a}
.btn-danger{background:#fff;color:var(--red);border-color:#f5b7b1}.btn-danger:hover{background:#fce8e6}
.btn-amber{background:#fff8e1;color:var(--amber);border-color:#f59e0b}.btn-amber:hover{background:#fff3c4}
.btn-purple{background:#ede7f6;color:#5c35aa;border-color:#c5b8ec}.btn-purple:hover{background:#e1d5f5}
.btn-sm{padding:3px 8px;font-size:11px}
.edit-banner{background:#fff8e1;border-bottom:2px solid var(--amber);padding:5px 18px;display:none;align-items:center;gap:12px;font-size:12px;font-weight:600;color:var(--amber)}
.edit-banner.on{display:flex}
.view{display:none;padding:18px 16px;max-width:1380px;margin:0 auto}
.view.active{display:block}
.ph{margin-bottom:14px;display:flex;justify-content:space-between;align-items:flex-start;flex-wrap:wrap;gap:10px}
.ph h2{font-size:18px;font-weight:700;color:var(--navy);cursor:pointer;border-radius:4px;padding:2px 5px;transition:background .12s}
.ph h2:hover{background:#fff3e0}
.ph h2[contenteditable=true]{outline:2px solid var(--amber);background:#fffde7}
.ph p{font-size:12px;color:var(--muted);margin-top:3px;cursor:pointer;border-radius:3px;padding:1px 4px}
.ph p:hover{background:#fff3e0}
.ph p[contenteditable=true]{outline:2px solid var(--amber);background:#fffde7}
.card{background:var(--white);border-radius:10px;border:1px solid var(--border);padding:18px 20px;margin-bottom:12px}
.card-sm{background:var(--white);border-radius:8px;border:1px solid var(--border);padding:11px 14px;margin-bottom:8px}
.metrics{display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:10px;margin-bottom:18px}
.metric{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:12px 15px;position:relative;transition:box-shadow .15s,border-color .15s}
.metric[onclick]:hover{box-shadow:0 3px 12px rgba(0,0,0,.1);border-color:var(--blue);cursor:pointer}
.metric-lbl{font-size:10px;color:#999;text-transform:uppercase;letter-spacing:.5px;margin-bottom:3px;cursor:pointer}
.metric-lbl:hover{color:var(--amber)}
.metric-lbl[contenteditable=true]{outline:1px solid var(--amber);background:#fffde7;border-radius:2px}
.metric-val{font-size:22px;font-weight:700}
.metric-del{position:absolute;top:6px;right:8px;display:none;font-size:10px;cursor:pointer;color:var(--red);font-weight:700}
.metric:hover .metric-del.edshow{display:block}
.badge{display:inline-flex;align-items:center;padding:2px 7px;border-radius:12px;font-size:11px;font-weight:600;white-space:nowrap}
.b-blue{background:#e8f0fc;color:#1a5fa8}.b-green{background:#e6f4ea;color:#276221}
.b-amber{background:#fef3e2;color:#8a4900}.b-red{background:#fce8e6;color:#c0392b}
.b-gray{background:#f1f1ec;color:#555}.b-purple{background:#ede7f6;color:#5c35aa}
.b-teal{background:#e0f7f4;color:#00695c}
.twrap{overflow-x:auto;border-radius:8px;border:1px solid var(--border)}
table{width:100%;border-collapse:collapse;font-size:12px}
th{background:var(--bg);padding:8px 11px;text-align:left;font-weight:700;color:#444;border-bottom:1px solid var(--border);white-space:nowrap;font-size:11px;position:relative;letter-spacing:.2px}
th.eh{cursor:pointer}
th.eh:hover{background:#fff3e0}
th.eh[contenteditable=true]{background:#fffde7;outline:2px solid var(--amber);outline-offset:-2px;cursor:text;white-space:normal;min-width:80px}
td{padding:8px 11px;border-bottom:1px solid #f0f0ea;vertical-align:middle}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafaf7}
.em tr:hover td{background:#fffbf0;cursor:pointer}
td.ce{padding:0}
td.ce input,td.ce select,td.ce textarea{border:none;background:#fffde7;padding:7px 10px;font-size:12px;width:100%;min-width:100px;outline:2px solid var(--amber);outline-offset:-2px;font-family:inherit}
td.ce textarea{min-height:64px;resize:vertical}
.rbtns{display:flex;gap:3px;opacity:.6;transition:opacity .12s}
tr:hover .rbtns{opacity:1}.rbtns:hover{opacity:1}
.rb{padding:2px 6px;border-radius:3px;font-size:10px;font-weight:700;cursor:pointer;border:1px solid}
.rb-e{background:#e8f0fc;color:#1a5fa8;border-color:#b5d4f4}
.rb-d{background:#fce8e6;color:#c0392b;border-color:#f5b7b1}
.rb-c{background:#e6f4ea;color:#276221;border-color:#a8d5b5}
.sbar{display:flex;gap:8px;flex-wrap:wrap;margin-bottom:12px;align-items:center}
.sbar input,.sbar select{padding:7px 10px;border:1px solid #ccc;border-radius:6px;font-size:12px;font-family:inherit}
.sbar input{max-width:240px}
.sbar input:focus,.sbar select:focus{outline:none;border-color:var(--blue)}
.fg2{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.fg{display:flex;flex-direction:column;gap:4px}
.fg.full{grid-column:1/-1}
.fg label{font-size:11px;font-weight:700;color:#555;text-transform:uppercase;letter-spacing:.3px}
.fg input,.fg select,.fg textarea{padding:8px 10px;border:1.5px solid #ddd;border-radius:6px;font-size:13px;font-family:inherit}
.fg input:focus,.fg select:focus,.fg textarea:focus{outline:none;border-color:var(--blue);box-shadow:0 0 0 2px rgba(26,95,168,.1)}
.fg textarea{resize:vertical;min-height:68px}
hr.d{border:none;border-top:1px solid #eee;margin:14px 0}
.sec-ttl{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.4px;color:#888;margin:14px 0 10px}
.mbg{display:none;position:fixed;inset:0;background:rgba(0,0,0,.48);z-index:500;overflow-y:auto;padding:24px 12px;align-items:flex-start;justify-content:center}
.mbg.open{display:flex}
.mc{background:var(--white);border-radius:12px;width:100%;max-width:820px;margin:auto;padding:24px 26px;position:relative;max-height:90vh;overflow-y:auto}
.mc-sm{max-width:480px}
.mclose{position:absolute;top:14px;right:14px;background:none;border:none;font-size:18px;cursor:pointer;color:#aaa;width:28px;height:28px;border-radius:5px;display:flex;align-items:center;justify-content:center}
.mclose:hover{background:var(--bg)}
.mc h2{font-size:16px;font-weight:700;color:var(--navy);margin-bottom:14px}
.inf{background:#e8f0fc;border-left:3px solid var(--blue);border-radius:0 6px 6px 0;padding:8px 13px;font-size:12px;color:#1a3f6f;margin-bottom:12px}
.wrn{background:#fef3e2;border-left:3px solid #f59e0b;border-radius:0 6px 6px 0;padding:8px 13px;font-size:12px;color:var(--amber);margin-bottom:12px}
.suc{background:#e6f4ea;border-left:3px solid var(--green);border-radius:0 6px 6px 0;padding:8px 13px;font-size:12px;color:#1a4a1e;margin-bottom:12px}
.live-banner{background:#e8f0fc;border:1px solid #b5d4f4;border-radius:8px;padding:10px 14px;font-size:12px;color:#1a3f6f;margin-bottom:14px;display:flex;align-items:center;gap:10px;flex-wrap:wrap}
.live-dot{width:8px;height:8px;border-radius:50%;background:#27ae60;flex-shrink:0;animation:pulse 2s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.savebar{position:fixed;bottom:0;left:0;right:0;background:var(--navy);color:#fff;padding:9px 18px;display:none;align-items:center;justify-content:space-between;z-index:400;font-size:13px}
.savebar.on{display:flex}
.rc{background:var(--white);border-radius:8px;border:1px solid var(--border);padding:13px 16px;margin-bottom:8px;cursor:pointer;transition:border-color .12s}
.rc:hover{border-color:var(--blue)}
.sbar2{height:6px;background:#eee;border-radius:3px;overflow:hidden;margin-top:7px}
.sf{height:100%;border-radius:3px}
.gl{display:flex;flex-wrap:wrap;gap:4px;margin-top:6px}
.gt{background:#fef3e2;color:var(--amber);font-size:10px;padding:2px 6px;border-radius:3px}
.mt{background:#e6f4ea;color:var(--green);font-size:10px;padding:2px 6px;border-radius:3px}
.cc{background:var(--white);border:1px solid var(--border);border-radius:9px;padding:13px 16px;display:flex;align-items:center;gap:14px;cursor:pointer;transition:all .12s}
.cc:hover{border-color:var(--blue);box-shadow:0 2px 8px rgba(0,0,0,.07)}
.cav{width:40px;height:40px;border-radius:50%;background:var(--navy);color:#fff;display:flex;align-items:center;justify-content:center;font-size:15px;font-weight:700;flex-shrink:0}
.tabg{display:flex;border-bottom:1px solid var(--border);margin-bottom:14px;flex-wrap:wrap}
.tabb{padding:7px 13px;font-size:12px;cursor:pointer;border:none;background:none;color:#888;font-weight:600;border-bottom:2px solid transparent;margin-bottom:-1px;font-family:inherit}
.tabb.on{color:var(--blue);border-bottom-color:var(--blue)}
.tabb:hover{color:var(--text);background:var(--light)}
.tabp{display:none}.tabp.on{display:block}
.pg{display:grid;grid-template-columns:repeat(auto-fill,minmax(230px,1fr));gap:10px}
.pc{background:var(--white);border:1px solid var(--border);border-radius:8px;padding:12px 15px;cursor:pointer;transition:border-color .12s}
.pc:hover{border-color:var(--blue)}
#toast{position:fixed;bottom:62px;right:18px;background:#1a1a1a;color:#fff;padding:9px 14px;border-radius:8px;font-size:12px;z-index:700;opacity:0;transform:translateY(6px);transition:all .2s;pointer-events:none;max-width:340px}
#toast.on{opacity:1;transform:translateY(0)}
.spinner{display:inline-block;width:14px;height:14px;border:2px solid #ddd;border-top-color:var(--blue);border-radius:50%;animation:spin .7s linear infinite;vertical-align:middle}
@keyframes spin{to{transform:rotate(360deg)}}
.tbl-section{margin-bottom:24px}
.tbl-section-header{display:flex;align-items:center;justify-content:space-between;margin-bottom:10px;gap:10px;flex-wrap:wrap}
.tbl-section-title{font-size:15px;font-weight:700;color:var(--navy);cursor:pointer;border-radius:4px;padding:2px 5px}
.tbl-section-title:hover{background:#fff3e0}
.tbl-section-title[contenteditable=true]{outline:2px solid var(--amber);background:#fffde7}
.field-row{display:flex;align-items:center;gap:8px;padding:7px 0;border-bottom:1px solid #f5f5f0;font-size:12px}
.field-row:last-child{border-bottom:none}
.empty{text-align:center;padding:40px;color:#bbb}
.upd-row{display:flex;align-items:center;gap:8px;padding:8px 12px;border-bottom:1px solid #f0f0ea;font-size:12px}
.upd-row:last-child{border-bottom:none}
@media(max-width:640px){.fg2{grid-template-columns:1fr}.nav-tabs{max-width:calc(100vw - 160px)}}
</style>
</head>
<body>

<div class="edit-banner" id="ebanner">
  ✏️ Edit Mode ON — click any cell, heading, column header, tab label, or metric to edit.
  <button class="btn btn-sec btn-sm" style="margin-left:auto" onclick="toggleEdit()">Turn Off</button>
</div>

<nav class="nav" id="main-nav">
  <div class="nav-brand" onclick="if(editMode)openLogoBrandEditor()">
    <div id="nav-logo-wrap" style="display:flex;align-items:center;gap:8px;cursor:pointer">
      <span id="nav-logo-icon" style="font-size:20px">🍁</span>
      <img id="nav-logo-img" style="display:none;height:32px;width:auto;border-radius:4px;object-fit:contain">
      <span class="nav-brand-text" id="nav-brand" data-heading="nav-brand">CANADA PNP</span>
    </div>
  </div>
  <div class="nav-tabs" id="nav-tabs"></div>
  <div class="nav-right">
    <div class="etoggle" id="etoggle" onclick="toggleEdit()">
      <div class="edot" id="edot"></div><span id="elbl">Edit Mode</span>
    </div>
    <button class="btn btn-blue btn-sm edit-mode-only" onclick="openPageTextManager()" style="display:none" title="Edit, hide or delete any heading or text">📝 Page Text</button>
    <button class="btn btn-purple btn-sm" onclick="openLiveUpdate()">🔄 Live Update</button>
    <button class="btn btn-amber btn-sm" onclick="openDesignModal()">🎨 Design</button>
    <button class="btn btn-sec btn-sm" onclick="openDataMgr()">💾 Backup</button>
  </div>
</nav>

<div id="views-container"></div>

<!-- ═══ PROGRAM DETAIL / EDIT MODAL ═══ -->
<div class="mbg" id="prog-modal">
  <div class="mc">
    <button class="mclose" onclick="closeM('prog-modal')">✕</button>
    <h2 id="pm-title">Program</h2>
    <div id="pm-body"></div>
    <div id="pm-actions" style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap"></div>
  </div>
</div>

<!-- ═══ CLIENT FORM MODAL ═══ -->
<div class="mbg" id="client-modal">
  <div class="mc">
    <button class="mclose" onclick="closeM('client-modal')">✕</button>
    <h2 id="cm-title">Client Profile</h2>
    <div id="client-form-body"></div>
    <div style="display:flex;gap:8px;margin-top:16px;flex-wrap:wrap">
      <button class="btn btn-primary" onclick="saveClient()">💾 Save Client</button>
      <button class="btn btn-success" onclick="saveAndMatch()">💾 Save &amp; Run Match</button>
      <button class="btn btn-sec"     onclick="closeM('client-modal')">Cancel</button>
      <button class="btn btn-danger btn-sm" id="del-client-btn" style="display:none;margin-left:auto" onclick="deleteCurrentClient()">🗑 Delete</button>
    </div>
  </div>
</div>

<!-- ═══ ADD/MANAGE TABLE MODAL ═══ -->
<div class="mbg" id="table-modal">
  <div class="mc mc-sm">
    <button class="mclose" onclick="closeM('table-modal')">✕</button>
    <h2 id="table-modal-title">Add New Table</h2>
    <div id="table-modal-body"></div>
  </div>
</div>

<!-- ═══ ADD FIELD MODAL ═══ -->
<div class="mbg" id="field-modal">
  <div class="mc mc-sm">
    <button class="mclose" onclick="closeM('field-modal')">✕</button>
    <h2 id="field-modal-title">Add Field</h2>
    <div id="field-modal-body"></div>
  </div>
</div>

<!-- ═══ COLUMN MANAGER MODAL ═══ -->
<div class="mbg" id="col-modal">
  <div class="mc mc-sm">
    <button class="mclose" onclick="closeM('col-modal')">✕</button>
    <h2>+ Add Column / Manage Columns</h2>

    <!-- ADD NEW — shown at top for easy access -->
    <div style="background:#e6f4ea;border-radius:8px;padding:14px 16px;margin-bottom:16px">
      <div style="font-size:12px;font-weight:700;color:#276221;margin-bottom:10px;text-transform:uppercase;letter-spacing:.3px">Add New Column to Programs Table</div>
      <div class="fg2" style="margin-bottom:10px">
        <div class="fg"><label>Column Label</label><input type="text" id="new-col-lbl" placeholder="e.g. Application Notes, Priority, Score" onkeydown="if(event.key==='Enter')addCustomCol()"></div>
        <div class="fg"><label>Data Type</label>
          <select id="new-col-type">
            <option value="text">Short Text</option>
            <option value="textarea">Long Text / Notes</option>
            <option value="number">Number</option>
            <option value="url">URL / Website Link</option>
            <option value="select">Dropdown (you set the options)</option>
          </select>
        </div>
      </div>
      <button class="btn btn-success btn-sm" onclick="addCustomCol()">+ Add Column</button>
    </div>

    <!-- EXISTING COLUMNS -->
    <div style="font-size:11px;font-weight:700;text-transform:uppercase;color:#888;letter-spacing:.3px;margin-bottom:8px">Existing Columns</div>
    <div class="inf" style="margin-bottom:8px">Check / uncheck to show or hide. Click the name to rename. System columns (🔒) cannot be removed.</div>
    <div id="col-list" style="max-height:40vh;overflow-y:auto"></div>
    <div style="margin-top:12px">
      <button class="btn btn-sec btn-sm" onclick="closeM('col-modal')">Done</button>
    </div>
  </div>
</div>

<!-- ═══ LIVE UPDATE MODAL ═══ -->
<div class="mbg" id="live-modal">
  <div class="mc" style="max-width:620px">
    <button class="mclose" onclick="closeM('live-modal')">✕</button>
    <h2>🔄 Live Program Update Check</h2>

    <!-- Step 1: API Key -->
    <div id="live-apikey-section">
      <div style="background:#e8f0fc;border-radius:8px;padding:14px 16px;margin-bottom:14px;font-size:13px;line-height:1.7">
        <strong>How this works:</strong> This feature uses the Anthropic Claude AI to visit each program's official government website right now and compare it to your saved data, then report any changes.<br><br>
        <strong>You need a free Anthropic API key.</strong> Get one at <a href="https://console.anthropic.com" target="_blank">console.anthropic.com</a> → Sign up → API Keys → Create Key. New accounts include free credits.
      </div>
      <div class="fg" style="margin-bottom:8px">
        <label>Your Anthropic API Key</label>
        <div style="display:flex;gap:8px">
          <input type="password" id="api-key-input" placeholder="sk-ant-api03-…" style="flex:1;padding:8px 10px;border:1.5px solid #ddd;border-radius:6px;font-size:13px;font-family:monospace">
          <button class="btn btn-sec btn-sm" onclick="toggleApiKeyVisibility()">👁</button>
        </div>
        <div style="font-size:11px;color:var(--muted);margin-top:4px">Your key is stored only in this browser session and never sent anywhere except directly to Anthropic's API.</div>
      </div>
      <button class="btn btn-success btn-sm" onclick="saveApiKey()" style="margin-bottom:4px">✓ Save Key &amp; Continue</button>
      <div id="apikey-status" style="font-size:11px;color:var(--muted);margin-top:6px"></div>
    </div>

    <!-- Step 2: Run checks (shown after key saved) -->
    <div id="live-check-section" style="display:none">
      <div class="suc" style="margin-bottom:12px">✅ API key saved for this session. You can now run live checks.</div>
      <div style="display:flex;gap:8px;margin-bottom:12px;flex-wrap:wrap;align-items:center">
        <button class="btn btn-sec btn-sm" onclick="document.getElementById('live-check-section').style.display='none';document.getElementById('live-apikey-section').style.display='block'">🔑 Change Key</button>
      </div>
      <div class="fg" style="margin-bottom:12px">
        <label>Select Program to Check</label>
        <select id="live-prog-select"><option value="">— Select a program —</option></select>
      </div>
      <div style="display:flex;gap:8px;margin-bottom:14px;flex-wrap:wrap">
        <button class="btn btn-blue btn-sm" onclick="runLiveCheck()">🔍 Check This Program</button>
        <button class="btn btn-sec btn-sm" onclick="checkAllPrograms()">🔍 Check All (up to 5 at a time)</button>
      </div>
      <div id="live-result" style="display:none;margin-bottom:14px"></div>
    </div>

    <hr class="d">
    <div class="sec-ttl">Update History</div>
    <div id="update-log" style="max-height:180px;overflow-y:auto;font-size:12px;border:1px solid var(--border);border-radius:6px;padding:8px"></div>
  </div>
