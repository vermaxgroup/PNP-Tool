function renderCalcNotices(calc){
  loadCalcNotices();
  const notices = CALC_NOTICES[calc]||[];
  const styles = {
    warn:'background:#fef3e2;border-left:3px solid #f59e0b;color:#92560a;border-radius:0 7px 7px 0',
    tip: 'background:#fff3cd;border-left:3px solid #ffc107;color:#856404;border-radius:7px',
    info:'background:#e8f0fc;border-left:3px solid #1a5fa8;color:#1a3f6f;border-radius:0 7px 7px 0',
    success:'background:#e6f4ea;border-left:3px solid #276221;color:#1a4a1e;border-radius:0 7px 7px 0',
  };
  let html = '';
  notices.forEach((n,i)=>{
    if(n.visible===false && !editMode) return;
    const opacity = n.visible===false ? 'opacity:.4;' : '';
    html += `<div style="${styles[n.style]||styles.info};padding:9px 13px;font-size:12px;margin-bottom:8px;display:flex;align-items:flex-start;gap:10px;${opacity}">`;
    if(editMode){
      html += `<span contenteditable="true" style="flex:1;outline:none;cursor:text" 
        onblur="updateCalcNotice('${calc}',${i},'text',this.textContent)"
        onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}">${esc(n.text||'')}</span>`;
      if(n.source){
        html += `<a href="${esc(n.source)}" target="_blank" style="font-size:10px;white-space:nowrap;flex-shrink:0">${esc(n.sourceLabel||'Source ↗')}</a>`;
      }
      html += `<div style="display:flex;gap:4px;flex-shrink:0;margin-left:6px">
        <button class="btn btn-sec btn-sm" style="font-size:10px;padding:2px 6px" onclick="toggleCalcNotice('${calc}',${i})">${n.visible===false?'Show':'Hide'}</button>
        <button class="btn btn-danger btn-sm" style="font-size:10px;padding:2px 6px" onclick="deleteCalcNotice('${calc}',${i})">✕</button>
      </div>`;
    } else {
      html += `<span style="flex:1">${esc(n.text||'')}`;
      if(n.source) html += ` <a href="${esc(n.source)}" target="_blank" style="color:inherit;font-size:10px">${esc(n.sourceLabel||'Source ↗')}</a>`;
      html += `</span>`;
    }
    html += `</div>`;
  });
  if(editMode){
    html += `<div style="margin-bottom:8px;display:flex;gap:6px;flex-wrap:wrap">
      <button class="btn btn-success btn-sm" style="font-size:11px" onclick="addCalcNotice('${calc}','warn')">+ Warning Notice</button>
      <button class="btn btn-blue btn-sm" style="font-size:11px" onclick="addCalcNotice('${calc}','info')">+ Info Notice</button>
      <button class="btn btn-amber btn-sm" style="font-size:11px" onclick="addCalcNotice('${calc}','tip')">+ Tip</button>
    </div>`;
  }
  return html;
}
function updateCalcNotice(calc, i, field, val){
  loadCalcNotices();
  if(!CALC_NOTICES[calc]||!CALC_NOTICES[calc][i]) return;
  CALC_NOTICES[calc][i][field] = (val||'').trim();
  saveCalcNotices();
}
function toggleCalcNotice(calc, i){
  loadCalcNotices();
  if(!CALC_NOTICES[calc]||!CALC_NOTICES[calc][i]) return;
  CALC_NOTICES[calc][i].visible = CALC_NOTICES[calc][i].visible===false ? true : false;
  saveCalcNotices();
  const tab = TABS.find(t=>t.type===calc);
  if(tab&&_activeTabId===tab.id){ calc==='crs'?renderCRS():renderFSW(); }
}
function deleteCalcNotice(calc, i){
  loadCalcNotices();
  if(!CALC_NOTICES[calc]) return;
  CALC_NOTICES[calc].splice(i,1);
  saveCalcNotices();
  const tab = TABS.find(t=>t.type===calc);
  if(tab&&_activeTabId===tab.id){ calc==='crs'?renderCRS():renderFSW(); }
}
function addCalcNotice(calc, style){
  loadCalcNotices();
  if(!CALC_NOTICES[calc]) CALC_NOTICES[calc]=[];
  CALC_NOTICES[calc].push({id:'cn_'+Date.now(), visible:true, style, text:'New notice — click to edit'});
  saveCalcNotices();
  const tab = TABS.find(t=>t.type===calc);
  if(tab&&_activeTabId===tab.id){ calc==='crs'?renderCRS():renderFSW(); }
}


// ── PAGE TEXT MANAGER — edit/hide any heading or text on any tab ──
const SK_HIDDEN_HEADINGS = 'cnpnp4_hidden_headings';

function openPageTextManager(){
  // Collect all data-heading elements currently in DOM
  const els = Array.from(document.querySelectorAll('[data-heading]'));
  const hidden = getHiddenHeadings();
  
  let rows = els.map(el=>{
    const key = el.dataset.heading;
    const tag = el.tagName.toLowerCase();
    const text = el.textContent.trim();
    const isHidden = hidden.includes(key);
    return {key, tag, text, isHidden};
  }).filter(r=>r.text||r.isHidden);
  
  // Add hidden ones that aren't in DOM
  hidden.forEach(key=>{
    if(!rows.find(r=>r.key===key)){
      const saved = getSavedHeadings();
      rows.push({key, tag:'?', text:saved[key]||'(hidden)', isHidden:true});
    }
  });
  
  document.getElementById('table-modal-title').textContent = '⚙ Manage All Page Text & Headings';
  document.getElementById('table-modal-body').innerHTML = `
    <div class="inf" style="margin-bottom:12px">
      Every heading and subheading in the tool is listed below. 
      Click <strong>✏ Edit</strong> to change text. Click <strong>Hide</strong> to hide a line from view. 
      Changes save automatically.
    </div>
    <div style="max-height:60vh;overflow-y:auto">
      <table style="width:100%;font-size:12px;border-collapse:collapse">
        <thead><tr style="background:var(--bg);position:sticky;top:0">
          <th style="padding:6px 10px;text-align:left;border:1px solid var(--border)">Key</th>
          <th style="padding:6px 10px;text-align:left;border:1px solid var(--border)">Current Text</th>
          <th style="padding:6px 10px;border:1px solid var(--border)">Actions</th>
        </tr></thead>
        <tbody>
          ${rows.map(r=>`<tr style="${r.isHidden?'opacity:.4;background:#fafafa':''}">
            <td style="border:1px solid var(--border);padding:5px 8px;font-size:10px;color:var(--muted);font-family:monospace">${esc(r.key)}</td>
            <td style="border:1px solid var(--border);padding:5px 8px">
              <input type="text" value="${esc(r.text)}" style="width:100%;border:none;font-size:12px;background:transparent;outline:none"
                onblur="saveHeadingFromManager('${r.key}',this.value)"
                onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}">
            </td>
            <td style="border:1px solid var(--border);padding:5px 8px;text-align:center;white-space:nowrap">
              <button class="btn btn-sec btn-sm" style="font-size:10px;margin-right:4px" onclick="toggleHeadingVisibility('${r.key}',this)">${r.isHidden?'Show':'Hide'}</button>
              <button class="btn btn-danger btn-sm" style="font-size:10px" onclick="clearHeadingText('${r.key}',this)">Clear</button>
            </td>
          </tr>`).join('')}
        </tbody>
      </table>
    </div>
    <div style="margin-top:12px;display:flex;gap:8px">
      <button class="btn btn-success btn-sm" onclick="restoreAllHeadings()">↺ Restore All Defaults</button>
      <button class="btn btn-sec btn-sm" onclick="closeM('table-modal')">Close</button>
    </div>`;
  document.getElementById('table-modal').classList.add('open');
}

function getHiddenHeadings(){
  try{ return JSON.parse(localStorage.getItem(SK_HIDDEN_HEADINGS))||[]; }
  catch{ return []; }
}
function saveHiddenHeadings(arr){ localStorage.setItem(SK_HIDDEN_HEADINGS, JSON.stringify(arr)); }
function getSavedHeadings(){
  try{ return JSON.parse(localStorage.getItem(SK.headings))||{}; }
  catch{ return {}; }
}

function saveHeadingFromManager(key, val){
  // Update the element text
  const el = document.querySelector('[data-heading="'+key+'"]');
  if(el) el.textContent = val;
  // Save to storage
  const h = getSavedHeadings();
  h[key] = val;
  localStorage.setItem(SK.headings, JSON.stringify(h));
  toast('Text saved');
}
function toggleHeadingVisibility(key, btn){
  const el = document.querySelector('[data-heading="'+key+'"]');
  const hidden = getHiddenHeadings();
  const idx = hidden.indexOf(key);
  if(idx>=0){
    // Show
    hidden.splice(idx,1);
    if(el){ el.style.display=''; el.style.visibility=''; }
    if(btn) btn.textContent='Hide';
  } else {
    // Hide
    hidden.push(key);
    if(el){ el.style.display='none'; }
    if(btn) btn.textContent='Show';
  }
  saveHiddenHeadings(hidden);
  toast(idx>=0 ? 'Text shown' : 'Text hidden');
}
function clearHeadingText(key, btn){
  const el = document.querySelector('[data-heading="'+key+'"]');
  if(el){ el.textContent=''; }
  const h = getSavedHeadings();
  h[key] = '';
  localStorage.setItem(SK.headings, JSON.stringify(h));
  toast('Text cleared');
}
function restoreAllHeadings(){
  saveHiddenHeadings([]);
  localStorage.removeItem(SK.headings);
  // Re-render current tab
  const tab=TABS.find(t=>t.id===_activeTabId);
  if(tab){
    if(tab.type==='dashboard')renderDash();
    else { renderNavTabs(); showTab(_activeTabId); }
  }
  closeM('table-modal');
  toast('✅ All headings restored to defaults');
}

// Apply hidden headings after every render
function applyHiddenHeadings(){
  const hidden = getHiddenHeadings();
  hidden.forEach(key=>{
    const el = document.querySelector('[data-heading="'+key+'"]');
    if(el) el.style.display='none';
  });
}

function init(){
  loadAll();
  loadCalcScores();
  loadCalcOpts();
  loadCalcFields();
  loadCalcCfg();
  loadCalcNotices();
  loadCompare();
  _activeTabId=TABS[0]?.id||'dashboard';
  applyDesignOnLoad();
  renderTabs();
  loadHeadings();
  loadLogo();
  if(!localStorage.getItem(SK.progs)){
    setTimeout(()=>toast('💡 Use tabs for CRS Calculator, FSW Calculator, Saved Scores, and Compare Clients. Click 🎨 Design to change colours.',6000),800);
  }
}
document.addEventListener('DOMContentLoaded',init);
</script>
