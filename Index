// ═══════════════════════════════════════════════════════════
// MATCHING ENGINE — fully dynamic, uses all client fields
// ═══════════════════════════════════════════════════════════
// ── Helper: normalise Yes/No/true/false values to boolean ──
function isYes(v){if(v===true||v==='true')return true;if(typeof v==='string')return v.toLowerCase().startsWith('yes')||v==='y';return false;}
function teerNum(v){const n=parseInt(String(v).replace(/[^0-9]/g,''));return isNaN(n)?null:n;}
function clbNum(v){const n=parseInt(String(v).replace(/[^0-9]/g,''));return isNaN(n)?0:n;}

function computeMatch(client){
  return PROGS.map(prog=>{
    const chk=[],gaps=[],met=[];

    // Age
    if(client.age!=null&&client.age!==''){
      if(parseInt(client.age)>=18){chk.push(1);met.push('Age ✓');}
      else{chk.push(0);gaps.push('Must be 18+');}
    }

    // Work Experience
    const reqExp=parseFloat(prog.expYears)||0;
    const hasExp=parseFloat(client.exp)||0;
    if(hasExp>=reqExp){chk.push(1);if(reqExp>0)met.push('Experience ✓');}
    else{chk.push(0);gaps.push(`Need ${reqExp} yr experience`);}

    // TEER — client stores "TEER 2 — Technical" or just "2"
    const progTeerText=String(prog.teerText||'');
    if(progTeerText){
      const progTeers=progTeerText.split(',').map(x=>parseInt(x.trim())).filter(n=>!isNaN(n));
      const clientTeer=teerNum(client.teer);
      if(progTeers.length>0&&clientTeer!==null){
        if(progTeers.includes(clientTeer)){chk.push(1);met.push(`TEER ${clientTeer} ✓`);}
        else{chk.push(0);gaps.push(`TEER ${clientTeer} not eligible (need: ${progTeerText})`);}
      }
    }

    // CLB — client stores "CLB 7" or "7"
    const reqCLB=parseInt(prog.clb)||0;
    const clientCLB=clbNum(client.clb);
    if(clientCLB>0){
      if(clientCLB>=reqCLB){chk.push(1);met.push(`CLB ${clientCLB} ✓`);}
      else{chk.push(0);gaps.push(`CLB: have ${clientCLB}, need ${reqCLB}`);}
    }else{chk.push(0);gaps.push('Language test score required');}

    // French NCLC
    const reqNclc=parseInt(prog.frClb)||0;
    const clientNclc=clbNum(client.frClb);
    if(reqNclc>0){
      if(clientNclc>=reqNclc){chk.push(1);met.push('French ✓');}
      else{chk.push(0);gaps.push(`French NCLC ${reqNclc} required (have ${clientNclc||'none'})`);}
    }

    // Job Offer — prog.jobOffer is now "Yes"/"No" string or legacy boolean
    const progNeedsJob=isYes(prog.jobOffer);
    const progNeedsPerm=isYes(prog.jobOfferPermanent);
    const clientJobProv=String(client.jprov||'');
    const clientJobVal=String(client.job||'');
    const clientHasPermJob=clientJobVal.includes('Permanent')||clientJobVal==='yes';
    const clientHasTempJob=clientJobVal.includes('Temporary')||clientJobVal==='temp';
    const clientHasJob=clientHasPermJob||clientHasTempJob;
    const progJobProv=String(prog.jobOfferProvince||'');
    if(progNeedsJob){
      const jobOk=clientHasJob&&(!progJobProv||clientJobProv===progJobProv)&&(!progNeedsPerm||clientHasPermJob);
      if(jobOk){chk.push(1);met.push('Job offer ✓');}
      else{chk.push(0);gaps.push(`Job offer required${progJobProv?' in '+progJobProv:''}${progNeedsPerm?' (permanent)':''}`);}
    }else{chk.push(1);met.push('No job offer required ✓');}

    // Express Entry
    const progNeedsEE=isYes(prog.eeRequired);
    const clientHasEE=String(client.ee||'').includes('Yes')||client.ee==='yes';
    if(progNeedsEE){
      if(clientHasEE){chk.push(1);met.push('Express Entry profile ✓');}
      else{chk.push(0);gaps.push('Active Express Entry profile required');}
    }

    // In Canada
    const progNeedsCanada=isYes(prog.inCanadaRequired);
    const clientInCanada=String(client.canada||'').includes('Yes')||client.canada==='yes';
    if(progNeedsCanada&&!clientInCanada){chk.push(0);gaps.push('Must currently be living in Canada');}

    // Entrepreneur checks
    const progType=String(prog.type||'').toLowerCase();
    const isEnt=progType.includes('entrepreneur')||progType.includes('business');
    if(isEnt){
      const reqNW=parseFloat(prog.networthMin)||0;
      const reqInv=parseFloat(prog.investMin)||0;
      const clientNW=parseFloat(client.nw)||0;
      const clientInv=parseFloat(client.inv)||0;
      if(reqNW>0){if(clientNW>=reqNW){chk.push(1);met.push('Net worth ✓');}else{chk.push(0);gaps.push(`Net worth: need $${reqNW.toLocaleString()} (have $${clientNW.toLocaleString()})`);}}
      if(reqInv>0){if(clientInv>=reqInv){chk.push(1);met.push('Investment capital ✓');}else{chk.push(0);gaps.push(`Investment: need $${reqInv.toLocaleString()} (have $${clientInv.toLocaleString()})`);}}
    }

    // Province preference bonus (no penalty if no match)
    const provPref=String(client.prov||'');
    const preferred=provPref&&provPref!=='No preference'&&prog.province===provPref;

    // Dynamic checks from custom client fields with matchKeys
    CLIENT_EXTRA_FIELDS.forEach(f=>{
      if(!f.matchKey)return;
      const clientVal=client[f.key];
      const progVal=prog[f.matchKey];
      if(clientVal===undefined||clientVal===''||clientVal==='— Select —')return;
      if(progVal===undefined||progVal==='')return;
      if(f.type==='number'){
        const cv=parseFloat(clientVal)||0;const pv=parseFloat(progVal)||0;
        if(cv>=pv){chk.push(1);met.push(`${f.lbl} ✓`);}else{chk.push(0);gaps.push(`${f.lbl}: need ${pv}`);}
      }else if(f.type==='select'||f.type==='text'){
        if(String(clientVal).toLowerCase()===String(progVal).toLowerCase()||isYes(clientVal)){chk.push(1);met.push(`${f.lbl} ✓`);}
      }
    });

    const total=chk.length,passed=chk.filter(x=>x===1).length;
    const score=total>0?Math.round((passed/total)*100):0;
    return{progId:prog.id,progName:prog.name,province:prog.province,type:prog.type,expressEntry:prog.expressEntry,fees:prog.fees,status:prog.status,score,gaps,met,preferred};
  }).sort((a,b)=>(b.preferred?1:0)-(a.preferred?1:0)||b.score-a.score);
}
function runMatchForClient(clientId){
  const c=CLIENTS.find(x=>x.id===clientId);if(!c)return;
  const match=computeMatch(c);
  const el=match.filter(r=>r.score>=80),pa=match.filter(r=>r.score>=50&&r.score<80),ne=match.filter(r=>r.score<50);
  const rid='res-'+Date.now();
  RESULTS.push({id:rid,clientId,clientName:c.name,date:new Date().toLocaleDateString(),_ts:Date.now(),eligible:el.length,partial:pa.length,notEligible:ne.length,results:match});
  saveAll('Match saved');renderClients();renderDash();showResult(rid);
  const resTab=TABS.find(t=>t.type==='results');if(resTab)showTab(resTab.id);
  toast(`✅ Match complete — ${el.length} eligible, ${pa.length} partial`);
}
function showResult(id){
  const r=RESULTS.find(x=>x.id===id);if(!r)return;
  const match=r.results||[];
  const el=match.filter(x=>x.score>=80),pa=match.filter(x=>x.score>=50&&x.score<80),ne=match.filter(x=>x.score<50);
  const card=res=>{
    const col=res.score>=80?'#27ae60':res.score>=50?'#e67e22':'#e74c3c';
    const stBadge=res.status==='Open'?'<span class="badge b-green" style="font-size:10px">Open</span>':res.status==='Paused'?'<span class="badge b-amber" style="font-size:10px">Paused</span>':'';
    return`<div class="rc" onclick="openDetail('${res.progId}')">
      <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:10px">
        <div><div style="font-weight:700;font-size:12px">${res.preferred?'⭐ ':''}${res.progName||'—'}</div>
        <div style="font-size:11px;color:var(--muted);margin-top:2px">${res.province||'—'} · <span class="badge ${tc(res.type)}" style="font-size:10px">${typeLabel(res.type)}</span> ${stBadge} ${res.fees?'· '+res.fees:''}</div></div>
        <div style="font-size:17px;font-weight:800;color:${col};min-width:44px;text-align:right">${res.score}%</div>
      </div>
      <div class="sbar2"><div class="sf" style="width:${res.score}%;background:${col}"></div></div>
      <div class="gl">${(res.met||[]).slice(0,5).map(m=>`<span class="mt">${m}</span>`).join('')}${(res.gaps||[]).map(g=>`<span class="gt">✗ ${g}</span>`).join('')}</div>
    </div>`;
  };
  const sub=document.getElementById('s-results');if(sub)sub.textContent=`Results for ${r.clientName||'Client'} — ${r.date} · ${el.length} eligible · ${pa.length} partial`;
  const ra=document.getElementById('results-area');if(!ra)return;
  ra.innerHTML=`
    <div class="metrics" style="margin-bottom:14px">
      <div class="metric"><div class="metric-lbl">Eligible (80%+)</div><div class="metric-val" style="color:#27ae60">${el.length}</div></div>
      <div class="metric"><div class="metric-lbl">Partial Match (50–79%)</div><div class="metric-val" style="color:#e67e22">${pa.length}</div></div>
      <div class="metric"><div class="metric-lbl">Not Eligible</div><div class="metric-val" style="color:#e74c3c">${ne.length}</div></div>
      <div class="metric"><div class="metric-lbl">Total Assessed</div><div class="metric-val">${match.length}</div></div>
    </div>
    ${el.length?`<div style="font-weight:700;font-size:11px;color:#27ae60;text-transform:uppercase;margin-bottom:8px;letter-spacing:.3px">✓ Eligible Programs (${el.length})</div>${el.map(card).join('')}`:''}
    ${pa.length?`<div style="font-weight:700;font-size:11px;color:#e67e22;text-transform:uppercase;margin:12px 0 8px;letter-spacing:.3px">⚡ Partial Match — Close to Qualifying (${pa.length})</div>${pa.map(card).join('')}`:''}
    ${ne.length?`<details><summary style="cursor:pointer;font-size:12px;color:var(--muted);padding:8px 0">Show ${ne.length} not eligible programs</summary>${ne.map(card).join('')}</details>`:''}
    <div style="margin-top:14px;background:var(--bg);border-radius:7px;padding:10px 13px;font-size:11px;color:#aaa">Preliminary assessment only. Requirements change frequently — always verify at official government sources before advising clients. This is not legal advice.</div>`;
}
function renderResults(){
  const q=(document.getElementById('r-q')?.value||'').toLowerCase();
