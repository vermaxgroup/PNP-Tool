// DROPDOWN OPTIONS EDITOR
// Allows editing options for any select field in programs,
// client profile, or custom tables
// ═══════════════════════════════════════════════════════════
let _optsTarget = null; // {type:'col'|'clientfield'|'customtablecol', ref, key}

function openDropdownEditor(type, ref, key, currentOpts, label){
  _optsTarget = {type, ref, key, currentOpts: [...currentOpts]};
  document.getElementById('opts-modal-title').textContent = 'Edit Options — ' + label;
  // Show field context info
  const infoEl = document.getElementById('opts-field-info');
  if(infoEl){
    const typeLabels = {col:'Program Database Field', clientfield:'Client Profile Field', customtablecol:'Custom Table Field'};
    infoEl.innerHTML = `<strong>${typeLabels[type]||type}:</strong> ${esc(label)} &nbsp;·&nbsp; <span id="opts-count">${currentOpts.length} option${currentOpts.length!==1?'s':''}</span>`;
  }
  renderOptsList(currentOpts);
  document.getElementById('opts-new-val').value = '';
  document.getElementById('opts-modal').classList.add('open');
  // Focus the add input
  setTimeout(()=>document.getElementById('opts-new-val')?.focus(), 100);
}
function renderOptsList(opts){
  const countEl = document.getElementById('opts-count');
  if(countEl) countEl.textContent = opts.length + ' option' + (opts.length!==1?'s':'');
  document.getElementById('opts-list').innerHTML = opts.length === 0
    ? '<div style="padding:20px;text-align:center;color:#bbb;font-size:12px">No options yet — add one below.</div>'
    : opts.map((o, i) => `
    <div style="display:flex;align-items:center;gap:8px;padding:9px 12px;border-bottom:1px solid #f5f5f0;font-size:13px;background:${i%2===0?'var(--white)':'var(--bg)'}">
      <span style="color:#bbb;font-size:11px;min-width:20px;text-align:right">${i+1}</span>
      <span style="flex:1" id="opt-span-${i}">${esc(o) || '<em style="color:#bbb">— empty placeholder —</em>'}</span>
      <button class="rb rb-e" onclick="editOptInline(${i})" title="Rename">✏</button>
      <button class="rb rb-d" onclick="deleteOpt(${i})" title="Delete">✕</button>
    </div>`).join('');
}
function editOptInline(i){
  const cur = _optsTarget.currentOpts[i];
  const span = document.getElementById('opt-span-'+i);
  if(!span) return;
  span.innerHTML = `<input type="text" value="${esc(cur)}" style="border:1.5px solid var(--blue);border-radius:5px;padding:4px 8px;font-size:13px;width:100%;max-width:260px;font-family:inherit">`;
  const inp = span.querySelector('input');
  inp.focus(); inp.select();
  const save = () => {
    const newVal = inp.value.trim();
    if(newVal) _optsTarget.currentOpts[i] = newVal;
    renderOptsList(_optsTarget.currentOpts);
  };
  inp.addEventListener('blur', save);
  inp.addEventListener('keydown', e => { if(e.key==='Enter'){e.preventDefault();inp.blur();} if(e.key==='Escape'){renderOptsList(_optsTarget.currentOpts);} });
}
function deleteOpt(i){
  const opt = _optsTarget.currentOpts[i];
  if(!confirm(`Delete option "${opt}"?`)) return;
  _optsTarget.currentOpts.splice(i,1);
  renderOptsList(_optsTarget.currentOpts);
}
function addDropdownOption(){
  const inp = document.getElementById('opts-new-val');
  const val = inp.value.trim();
  if(!val){ toast('⚠ Type an option value first'); inp.focus(); return; }
  if(_optsTarget.currentOpts.includes(val)){ toast('⚠ That option already exists'); return; }
  _optsTarget.currentOpts.push(val);
  inp.value = '';
  inp.focus();
  renderOptsList(_optsTarget.currentOpts);
  // Scroll to bottom of list to show newly added item
  const list = document.getElementById('opts-list');
  if(list) list.scrollTop = list.scrollHeight;
}
function saveDropdownOptions(){
  const {type, ref, key, currentOpts} = _optsTarget;
  if(currentOpts.length === 0){
    if(!confirm('Save with no options? The dropdown will be empty.')) return;
  }
  let label = key;
  if(type === 'col'){
    const col = COLS.find(c => c.key === key);
    if(col){ col.opts = currentOpts; label = col.lbl; }
  } else if(type === 'clientfield'){
    const f = BASE_CLIENT_FIELDS.find(f => f.key === key) || CLIENT_EXTRA_FIELDS.find(f => f.key === key);
    if(f){ f.opts = currentOpts; label = f.lbl; }
  } else if(type === 'customtablecol'){
    const tab = TABS.find(t => t.id === ref);
    const col = tab?.cols?.find(c => c.key === key);
    if(col){ col.opts = currentOpts; label = col.lbl; }
  }
  saveAll('Dropdown options updated');
  closeM('opts-modal');
  // Re-render everything so changes appear immediately everywhere
  const activeTab = TABS.find(t => t.id === _activeTabId);
  if(activeTab){
    if(activeTab.type==='programs'){renderProgs();}
    else if(activeTab.type==='clients'){renderClients();}
    else if(activeTab.type==='dashboard'){renderDash();}
    else if(activeTab.type==='custom_table'){renderCustomTable(activeTab);}
  }
  toast(`✅ Saved ${currentOpts.length} options for "${label}" — matching engine updated`);
  showSaveBar(`"${label}" dropdown options saved and applied everywhere`);
}

// ═══════════════════════════════════════════════════════════
// CROSS-TABLE FORMULAS FOR CUSTOM TABLES
// ═══════════════════════════════════════════════════════════
// Formula syntax: =COUNT(programs, "status", "Open")
//                 =SUM(programs, "networthMin")
//                 =LIST(programs, "province", "type", "entrepreneur")
//                 =MATCH(clients, "prov", "Ontario")
//                 =CALC: any JS using progs/clients/results arrays

function evalCellFormula(val){
  if(typeof val !== 'string' || !val.startsWith('=')) return val;
  const expr = val.slice(1).trim();
  try{
    // Shorthand formulas
    const countMatch = expr.match(/^COUNT\((\w+),\s*"([^"]+)",\s*"([^"]+)"\)/i);
    if(countMatch) return String(getDataset(countMatch[1]).filter(r => r[countMatch[2]] === countMatch[3]).length);

    const sumMatch = expr.match(/^SUM\((\w+),\s*"([^"]+)"\)/i);
    if(sumMatch) return String(getDataset(sumMatch[1]).reduce((s,r)=>s+(parseFloat(r[sumMatch[2]])||0),0).toLocaleString());

    const listMatch = expr.match(/^LIST\((\w+),\s*"([^"]+)"(?:,\s*"([^"]+)",\s*"([^"]+)")?\)/i);
    if(listMatch){
      let data = getDataset(listMatch[1]);
      if(listMatch[3]) data = data.filter(r => r[listMatch[3]] === listMatch[4]);
      return [...new Set(data.map(r=>r[listMatch[2]]).filter(Boolean))].join(', ');
    }

    const matchMatch = expr.match(/^MATCH\((\w+),\s*"([^"]+)",\s*"([^"]+)"\)/i);
    if(matchMatch) return String(getDataset(matchMatch[1]).filter(r => r[matchMatch[2]] === matchMatch[3]).map(r=>r.name||r[Object.keys(r)[0]]).join(', '));

    // Raw JS: CALC: expression
    const calcMatch = expr.match(/^CALC:\s*(.+)/i);
    if(calcMatch) return String(new Function('progs','clients','results','return '+calcMatch[1])(PROGS,CLIENTS,RESULTS));

    return val; // Unknown formula, return as-is
  } catch(e){ return '#ERR'; }
}
function getDataset(name){
  const n = name.toLowerCase();
  if(n==='programs'||n==='progs') return PROGS;
  if(n==='clients') return CLIENTS;
  if(n==='results') return RESULTS;
  // Also check custom table names
  const tab = TABS.find(t=>(t.lbl||'').toLowerCase()===n);
  return tab?.rows||[];
}

// Override renderCustomTable to evaluate formulas
function renderCustomTable(tab){
  const thead = document.getElementById('cthead-'+tab.id);
  const tbody = document.getElementById('ctbody-'+tab.id);
  if(!thead||!tbody) return;
  const cols = tab.cols||[], rows = tab.rows||[], em = editMode;

  thead.innerHTML = `<tr>${cols.map(c=>{
    const isSelect = c.type === 'select';
    return `<th class="${em?'eh':''}" onclick="if(editMode)editCustomColHeader('${tab.id}','${c.key}',this)">${esc(c.lbl)}${em?'<span style="opacity:.35;font-size:9px;margin-left:3px">✏</span>':''}${em&&isSelect?`<button class="rb rb-e" style="margin-left:4px;font-size:9px" onclick="event.stopPropagation();openDropdownEditorByKey('customtablecol','${tab.id}','${c.key}')">⚙</button>`:''}`;
  }).join('')}<th style="width:80px">Actions</th></tr>`;

  tbody.innerHTML = rows.length===0
    ? `<tr><td colspan="${cols.length+1}" style="text-align:center;padding:24px;color:#bbb">No rows yet. Click "+ Add Row" to add one.</td></tr>`
    : rows.map(row=>`<tr>
        ${cols.map(c=>{
          const rawVal = row[c.key]||'';
          const displayVal = evalCellFormula(rawVal);
          const isFormula = typeof rawVal==='string' && rawVal.startsWith('=');
          return `<td ${em?`onclick="customCellClick(event,'${tab.id}','${row.id}','${c.key}')"`:''}><span style="font-size:12px${isFormula?';color:var(--blue);font-weight:500':''}">${displayVal||'—'}</span></td>`;
        }).join('')}
        <td><div class="rbtns"><button class="rb rb-d" onclick="deleteCustomRow('${tab.id}','${row.id}')">✕</button></div></td>
      </tr>`).join('');
}

function editCustomColHeader(tabId,key,th){
  if(!editMode)return;
  const tab=TABS.find(t=>t.id===tabId);const col=tab?.cols?.find(c=>c.key===key);if(!col)return;
  const cur=col.lbl;
  th.innerHTML=`<input type="text" value="${cur}" style="border:none;background:#fffde7;font-size:11px;font-weight:700;width:100%;padding:2px 4px;outline:none;min-width:80px">`;
  const inp=th.querySelector('input');inp.focus();inp.select();
  inp.addEventListener('blur',()=>{col.lbl=inp.value.trim()||cur;saveAll('Column renamed');renderCustomTable(tab);});
  inp.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();inp.blur();}});
}
function customCellClick(e,tabId,rowId,key){
  if(!editMode)return;
  const tab=TABS.find(t=>t.id===tabId);if(!tab)return;
  const row=tab.rows?.find(r=>r.id===rowId);if(!row)return;
  const col=tab.cols?.find(c=>c.key===key);
  const td=e.currentTarget;if(td.classList.contains('ce'))return;
  const cur=row[key]||'';
  td.classList.add('ce');
  let inp;
  if(col?.type==='select'&&col?.opts?.length){
    inp=document.createElement('select');
    col.opts.forEach(o=>{const op=document.createElement('option');op.value=o;op.textContent=o||'—';if(o===cur)op.selected=true;inp.appendChild(op);});
  }else{
    inp=document.createElement('input');inp.type='text';inp.value=cur;
    inp.placeholder='Start with = for a formula (e.g. =COUNT(programs,"status","Open"))';
  }
  td.innerHTML='';td.appendChild(inp);inp.focus();
  if(inp.type!=='select')inp.select?.();
  inp.addEventListener('blur',()=>{row[key]=inp.value;td.classList.remove('ce');saveAll('Cell updated');renderCustomTable(tab);});
  inp.addEventListener('keydown',ev=>{if(ev.key==='Enter'&&inp.tagName!=='SELECT'){ev.preventDefault();inp.blur();}if(ev.key==='Escape'){td.classList.remove('ce');renderCustomTable(tab);}});
}
function addCustomTableRow(tabId){
  const tab=TABS.find(t=>t.id===tabId);if(!tab)return;
  if(!tab.rows)tab.rows=[];
  const row={id:'r_'+Date.now()};(tab.cols||[]).forEach(c=>row[c.key]='');
  tab.rows.push(row);saveAll('Row added');renderCustomTable(tab);
}
function deleteCustomRow(tabId,rowId){
  const tab=TABS.find(t=>t.id===tabId);if(!tab)return;
  tab.rows=(tab.rows||[]).filter(r=>r.id!==rowId);saveAll('Row deleted');renderCustomTable(tab);
}
function addCustomCol2(tabId){
  const tab=TABS.find(t=>t.id===tabId);if(!tab)return;
  const lbl=(document.getElementById('ct-col-lbl')?.value||'').trim();
  const type=(document.getElementById('ct-col-type')?.value)||'text';
  if(!lbl){toast('Column label required');return;}
  const key='c_'+lbl.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,15)+'_'+Date.now().toString().slice(-4);
  if(!tab.cols)tab.cols=[];
  const newCol={key,lbl,type,show:true};
  if(type==='select')newCol.opts=['Option 1','Option 2','Option 3'];
  tab.cols.push(newCol);
  (tab.rows||[]).forEach(r=>r[key]='');
  const lblEl=document.getElementById('ct-col-lbl');if(lblEl)lblEl.value='';
  saveAll('Column added');manageCustomTableCols(tabId);renderCustomTable(tab);toast('✅ Column "'+lbl+'" added');
}
function removeCustomCol(tabId,key){
  const tab=TABS.find(t=>t.id===tabId);if(!tab)return;
  tab.cols=(tab.cols||[]).filter(c=>c.key!==key);
  (tab.rows||[]).forEach(r=>delete r[key]);
  saveAll('Column removed');manageCustomTableCols(tabId);renderCustomTable(tab);
}

