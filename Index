// ═══════════════════════════════════════════════════════════
// PERSIST
// ═══════════════════════════════════════════════════════════
function saveAll(msg){
  localStorage.setItem(SK.progs,JSON.stringify(PROGS));
  localStorage.setItem(SK.cols,JSON.stringify(COLS));
  localStorage.setItem(SK.clients,JSON.stringify(CLIENTS));
  localStorage.setItem(SK.results,JSON.stringify(RESULTS));
  localStorage.setItem(SK.tabs,JSON.stringify(TABS));
  localStorage.setItem(SK.customTables,JSON.stringify(CUSTOM_TABLES));
  localStorage.setItem(SK.clientFields,JSON.stringify(CLIENT_EXTRA_FIELDS));
  localStorage.setItem(SK.metrics,JSON.stringify(CUSTOM_METRICS));
  localStorage.setItem(SK.updateLog,JSON.stringify(UPDATE_LOG));
  saveHeadings();
  showSaveBar(msg||'Changes saved');
}
function loadAll(){
  try{PROGS=JSON.parse(localStorage.getItem(SK.progs))||cloneDefault();}catch{PROGS=cloneDefault();}
  try{COLS=JSON.parse(localStorage.getItem(SK.cols))||JSON.parse(JSON.stringify(BASE_COLS));}catch{COLS=JSON.parse(JSON.stringify(BASE_COLS));}
  try{CLIENTS=JSON.parse(localStorage.getItem(SK.clients))||[];}catch{CLIENTS=[];}
  try{RESULTS=JSON.parse(localStorage.getItem(SK.results))||[];}catch{RESULTS=[];}
  try{
    const saved=JSON.parse(localStorage.getItem(SK.tabs));
    if(saved&&saved.length){
      // Merge: keep saved tabs, but add any new default tabs that don't exist yet
      TABS=saved;
      DEFAULT_TABS.forEach(dt=>{
        if(!TABS.find(t=>t.id===dt.id)) TABS.push(JSON.parse(JSON.stringify(dt)));
      });
    }else{
      TABS=JSON.parse(JSON.stringify(DEFAULT_TABS));
    }
  }catch{TABS=JSON.parse(JSON.stringify(DEFAULT_TABS));}
  try{CUSTOM_TABLES=JSON.parse(localStorage.getItem(SK.customTables))||[];}catch{CUSTOM_TABLES=[];}
  try{CLIENT_EXTRA_FIELDS=JSON.parse(localStorage.getItem(SK.clientFields))||[];}catch{CLIENT_EXTRA_FIELDS=[];}
  try{
    const savedM=JSON.parse(localStorage.getItem(SK.metrics));
    if(savedM&&savedM.length){
      CUSTOM_METRICS=savedM;
      // Merge navLink from defaults if missing
      DEFAULT_METRICS.forEach(dm=>{ const m=CUSTOM_METRICS.find(x=>x.id===dm.id); if(m&&!m.navLink&&dm.navLink)m.navLink=dm.navLink; });
    }else{
      CUSTOM_METRICS=JSON.parse(JSON.stringify(DEFAULT_METRICS));
    }
  }catch{CUSTOM_METRICS=JSON.parse(JSON.stringify(DEFAULT_METRICS));}
  try{UPDATE_LOG=JSON.parse(localStorage.getItem(SK.updateLog))||[];}catch{UPDATE_LOG=[];}
}
function saveHeadings(){
  const h={};
  document.querySelectorAll('[data-heading]').forEach(el=>h[el.dataset.heading]=el.textContent.trim());
  localStorage.setItem(SK.headings,JSON.stringify(h));
}
function loadHeadings(){
  try{
    const h=JSON.parse(localStorage.getItem(SK.headings))||{};
    Object.entries(h).forEach(([k,v])=>{const el=document.querySelector(`[data-heading="${k}"]`);if(el&&v)el.textContent=v;});
  }catch{}
  const t=localStorage.getItem(SK.pgtitle);
  if(t){document.getElementById('page-title-tag').textContent=t;const el=document.getElementById('pg-title-input');if(el)el.value=t;}
}
function tc(t){const s=String(t||'').toLowerCase();return(s.includes('entrepreneur')||s.includes('business'))?'b-red':s.includes('graduate')?'b-green':'b-blue';}
function typeLabel(t){const s=String(t||'').toLowerCase();if(s.includes('entrepreneur')||s.includes('business'))return'Entrepreneur / Business';if(s.includes('graduate'))return'Graduate';if(s.includes('skilled'))return'Skilled Worker';return t||'—';}
function statusLabel(v){const s=String(v||'');if(s==='Open')return'Open';if(s==='Paused')return'Paused';if(s==='Closed')return'Closed';if(s.includes('Intake'))return'Intake Limited';return s||'—';}
// Safe HTML escape
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');}

// ═══════════════════════════════════════════════════════════
// TABS — dynamic tab system
// ═══════════════════════════════════════════════════════════
function renderTabs(){
  renderNavTabs();
  renderViews();
}
function editTabLabel(span){
  if(!editMode)return;
  span.contentEditable='true';
  span.focus();
  const range=document.createRange();range.selectNodeContents(span);
  const sel=window.getSelection();sel.removeAllRanges();sel.addRange(range);
  const save=()=>{
    span.contentEditable='false';
    const tabId=span.closest('[data-tabid]')?.dataset.tabid;
    const tab=TABS.find(t=>t.id===tabId);
    if(tab){tab.lbl=span.textContent.trim()||tab.lbl;}
    saveAll('Tab renamed');
  };
  span.addEventListener('blur',save,{once:true});
  span.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();span.blur();}});
}
function showTab(tabId){
  _activeTabId=tabId;
  document.querySelectorAll('.nav-tab').forEach(el=>el.classList.remove('active'));
  const activeNav=document.querySelector(`[data-tabid="${tabId}"]`);
  if(activeNav)activeNav.classList.add('active');
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  const view=document.getElementById('view-'+tabId);
  if(view)view.classList.add('active');
  // Re-render the active view
  const tab=TABS.find(t=>t.id===tabId);
  if(!tab)return;
  if(tab.type==='dashboard')renderDash();
  else if(tab.type==='programs'){populateProvDD();renderProgs();}
  else if(tab.type==='clients')renderClients();
  else if(tab.type==='results')renderResults();
  else if(tab.type==='custom_table')renderCustomTable(tab);
  else if(tab.type==='crs')renderCRS();
  else if(tab.type==='fsw')renderFSW();
  else if(tab.type==='scores')renderSavedScores();
  else if(tab.type==='compare')renderCompare();
  setTimeout(applyHiddenHeadings, 30);
}
