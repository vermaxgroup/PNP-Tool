function cellClick(e,progId,key){
  if(!editMode)return;
  const td=e.currentTarget;if(td.classList.contains('ce'))return;
  const p=PROGS.find(x=>x.id===progId);const c=COLS.find(x=>x.key===key);if(!p||!c)return;
  const val=p[key]!==undefined?p[key]:'';
  td.classList.add('ce');
  const wrapper=document.createElement('div');
  wrapper.style.cssText='display:flex;align-items:center;gap:4px;padding:0';
  let inp;
  if(c.type==='checkbox'){
    inp=document.createElement('select');
    [['true','Yes'],['false','No']].forEach(([v,l])=>{const o=document.createElement('option');o.value=v;o.textContent=l;if(String(val)===v)o.selected=true;inp.appendChild(o);});
  } else if(c.type==='select'&&c.opts){
    inp=document.createElement('select');
    c.opts.forEach(o=>{const op=document.createElement('option');op.value=o;op.textContent=o||'— Select —';if(o===val)op.selected=true;inp.appendChild(op);});
    // Add ⚙ button to edit options without leaving the cell
    const editBtn=document.createElement('button');
    editBtn.textContent='⚙';
    editBtn.title='Edit dropdown options';
    editBtn.style.cssText='border:1px solid var(--border);background:var(--white);border-radius:3px;padding:2px 5px;font-size:10px;cursor:pointer;flex-shrink:0;color:var(--amber)';
    editBtn.onmousedown=(ev)=>{
      ev.preventDefault();
      const currentOpts=[...c.opts];
      td.classList.remove('ce');td.innerHTML='';
      // Save current value first
      p[key]=inp.value;if(c.type==='number')p[key]=parseFloat(inp.value)||0;
      openDropdownEditor('col',null,key,currentOpts,c.lbl);
    };
    wrapper.appendChild(inp);wrapper.appendChild(editBtn);
  } else if(c.type==='textarea'){
    inp=document.createElement('textarea');inp.value=String(val);inp.rows=3;
    inp.style.minWidth='220px';
  } else {
    inp=document.createElement('input');inp.type=c.type==='number'?'number':'text';inp.value=String(val);
  }
  inp.style.cssText='border:none;background:#fffde7;padding:6px 8px;font-size:12px;font-family:inherit;flex:1;min-width:80px;outline:none';
  if(!wrapper.contains(inp))wrapper.appendChild(inp);
  td.innerHTML='';td.appendChild(wrapper);inp.focus();
  if(inp.select&&c.type!=='select')inp.select();
  const saveCell=()=>{
    let nv=inp.value;
    if(c.type==='checkbox')nv=nv==='true';
    else if(c.type==='number')nv=parseFloat(nv)||0;
    p[key]=nv;td.classList.remove('ce');saveAll('Cell updated');renderProgs();
  };
  inp.addEventListener('blur',ev=>{if(!ev.relatedTarget||!td.contains(ev.relatedTarget))saveCell();});
  inp.addEventListener('keydown',ev=>{if(ev.key==='Enter'&&c.type!=='textarea'){ev.preventDefault();inp.blur();}if(ev.key==='Escape'){td.classList.remove('ce');renderProgs();}});
}
