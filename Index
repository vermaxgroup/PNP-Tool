// Compare table stored as {cols:[{id,label}], rows:[{id,cells:{colId:value}}]}
const SK_COMPARE = 'cnpnp4_compare';
let COMPARE_DATA = {cols:[], rows:[]};

function loadCompare(){
  try{ COMPARE_DATA = JSON.parse(localStorage.getItem(SK_COMPARE))||{cols:[],rows:[]}; }
  catch{ COMPARE_DATA = {cols:[],rows:[]}; }
  if(!COMPARE_DATA.cols) COMPARE_DATA.cols=[];
  if(!COMPARE_DATA.rows) COMPARE_DATA.rows=[];
}
function saveCompare(){ localStorage.setItem(SK_COMPARE, JSON.stringify(COMPARE_DATA)); }

function renderCompare(){
  loadCompare();
  const el = document.getElementById('compare-table-wrap'); if(!el) return;
  const {cols, rows} = COMPARE_DATA;
  if(!cols.length && !rows.length){
    el.innerHTML='<div class="empty" style="padding:40px">Click "+ Add Column" to add your first column, then "+ Add Row" to add items to compare.</div>';
    return;
  }
  // Build table
  let html='<table><thead><tr><th style="min-width:120px">Item / Label</th>';
  cols.forEach(c=>{
    html+=`<th style="min-width:120px;position:relative">
      <div style="display:flex;align-items:center;gap:4px">
        <span contenteditable="true" style="flex:1;min-width:60px;outline:none" 
          onblur="renameCompareCol('${c.id}',this.textContent)"
          onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}">${esc(c.label)}</span>
        <button class="rb rb-d" style="font-size:10px" onclick="deleteCompareCol('${c.id}')">✕</button>
      </div>
    </th>`;
  });
  html+='<th style="width:60px">Del</th></tr></thead><tbody>';
  
  rows.forEach(r=>{
    html+=`<tr><td style="font-weight:600"><span contenteditable="true" style="outline:none"
      onblur="renameCompareRow('${r.id}',this.textContent)"
      onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}">${esc(r.label||'')}</span></td>`;
    cols.forEach(c=>{
      const val=r.cells&&r.cells[c.id]||'';
      html+=`<td><span contenteditable="true" style="display:block;min-height:20px;outline:none;padding:2px 0"
        onblur="setCmpCell('${r.id}','${c.id}',this.textContent)"
        onkeydown="if(event.key==='Enter'){event.preventDefault();this.blur()}">${esc(val)}</span></td>`;
    });
    html+=`<td><button class="rb rb-d" onclick="deleteCompareRow('${r.id}')">✕</button></td></tr>`;
  });
  
  html+='</tbody></table>';
  el.innerHTML=html;
}
function addCompareCol(){
  const label=prompt('Column name (e.g. CLB Score, Province, Fees, Notes):','');
  if(!label)return;
  const id='cc_'+Date.now();
  COMPARE_DATA.cols.push({id,label});
  COMPARE_DATA.rows.forEach(r=>{if(!r.cells)r.cells={};r.cells[id]='';});
  saveCompare(); renderCompare();
}
function addCompareRow(){
  const label=prompt('Row label (e.g. client name, program name, or anything):','');
  if(!label)return;
  const id='cr_'+Date.now();
  const cells={};
  COMPARE_DATA.cols.forEach(c=>cells[c.id]='');
  COMPARE_DATA.rows.push({id,label,cells});
  saveCompare(); renderCompare();
}
function renameCompareCol(id,val){
  const c=COMPARE_DATA.cols.find(x=>x.id===id);
  if(c&&val.trim()){c.label=val.trim();saveCompare();}
}
function renameCompareRow(id,val){
  const r=COMPARE_DATA.rows.find(x=>x.id===id);
  if(r&&val.trim()){r.label=val.trim();saveCompare();}
}
function setCmpCell(rowId,colId,val){
  const r=COMPARE_DATA.rows.find(x=>x.id===rowId);
  if(r){if(!r.cells)r.cells={};r.cells[colId]=val.trim();saveCompare();}
}
function deleteCompareCol(id){
  COMPARE_DATA.cols=COMPARE_DATA.cols.filter(c=>c.id!==id);
  COMPARE_DATA.rows.forEach(r=>{if(r.cells)delete r.cells[id];});
  saveCompare(); renderCompare();
}
function deleteCompareRow(id){
  COMPARE_DATA.rows=COMPARE_DATA.rows.filter(r=>r.id!==id);
  saveCompare(); renderCompare();
}
function clearCompareTable(){
  if(!confirm('Clear all rows and columns?'))return;
  COMPARE_DATA={cols:[],rows:[]};
  saveCompare(); renderCompare();
}
function exportCompareCsv(){
  loadCompare();
  const {cols,rows}=COMPARE_DATA;
  if(!cols.length&&!rows.length){toast('Nothing to export');return;}
  const hdr=['"Item"',...cols.map(c=>'"'+c.label.replace(/"/g,'""')+'"')].join(',');
  const dataRows=rows.map(r=>['"'+(r.label||'').replace(/"/g,'""')+'"',...cols.map(c=>'"'+((r.cells&&r.cells[c.id])||'').replace(/"/g,'""')+'"')].join(','));
  const csv=[hdr,...dataRows].join('\n');
  const b=new Blob([csv],{type:'text/csv'});
  const a=document.createElement('a');a.href=URL.createObjectURL(b);
  a.download='comparison_'+new Date().toISOString().split('T')[0]+'.csv';a.click();
  toast('⬇ Comparison exported');
}

function exportScoresCSV(){
