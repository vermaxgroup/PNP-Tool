// ─────────────────────────────────────────────────────────
const CRS_AGE = {
  with:    {17:0,18:90,19:95,20:100,21:100,22:100,23:100,24:100,25:100,26:100,27:100,28:100,29:100,30:95,31:90,32:85,33:80,34:75,35:70,36:65,37:60,38:55,39:50,40:45,41:35,42:25,43:15,44:5,45:0},
  without: {17:0,18:99,19:105,20:110,21:110,22:110,23:110,24:110,25:110,26:110,27:110,28:110,29:110,30:105,31:99,32:94,33:88,34:83,35:77,36:72,37:66,38:61,39:55,40:50,41:39,42:28,43:17,44:6,45:0},
};
const CRS_EDU = {
  with:    {'none':0,'secondary':28,'1yr':84,'2yr':91,'bachelor':112,'two_three':119,'masters':126,'phd':140},
  without: {'none':0,'secondary':30,'1yr':90,'2yr':98,'bachelor':120,'two_three':128,'masters':135,'phd':150},
};
const CRS_LANG1 = { // per ability (×4)
  with:    {none:0,'<4':0,'4-5':6,'6':8,'7':16,'8':22,'9':29,'10+':32},
  without: {none:0,'<4':0,'4-5':6,'6':9,'7':17,'8':23,'9':31,'10+':34},
};
const CRS_LANG2 = { // per ability (×4), capped at 22 with/24 without
  with:    {none:0,'<5':0,'5-6':1,'7-8':3,'9+':6},
  without: {none:0,'<5':0,'5-6':1,'7-8':3,'9+':6},
};
const CRS_CANWORK = {
  with:    {'0':0,'1':35,'2':46,'3':56,'4':63,'5+':70},
  without: {'0':0,'1':40,'2':53,'3':64,'4':72,'5+':80},
};
const CRS_SPOUSE_EDU   = {'none':0,'secondary':2,'1yr':6,'2yr':7,'bachelor':8,'two_three':9,'masters':10,'phd':10};
const CRS_SPOUSE_LANG1 = {'<4':0,'5-6':1,'7-8':3,'9+':5}; // per ability ×4, max 20
const CRS_SPOUSE_WORK  = {'0':0,'1':5,'2':7,'3':8,'4':9,'5+':10};

// CRS Additional points (max 600)
// Sibling in Canada: 15
// French NCLC7+ all four + English CLB4 or lower: 25
// French NCLC7+ all four + English CLB5+ all four: 50
// Canadian education 1-2yr: 15
// Canadian education 3yr+: 30
// Provincial/territorial nomination: 600

// Skill Transferability (max 100 total; each sub-max 50)
// Education + Lang CLB7-8: 13 | CLB9+: 25 (1yr+ post-sec); 25 | 50 (2+ or masters/phd)
// Education + CanWork 1yr: 13-25 | 2yr+: 25-50
// ForeignWork + Lang CLB7-8: 13 | CLB9+: 25 (1-2yr foreign); 25 | 50 (3yr+ foreign)
// ForeignWork + CanWork 1yr: 13-25 | 2yr+: 25-50
// Trade cert + Lang CLB5-6: 25 | CLB7+: 50

// ─────────────────────────────────────────────────────────
// CRS CALCULATOR ENGINE
// ─────────────────────────────────────────────────────────
function calcCRS(d) {
  const sp = d.hasSpouse;
  const k = sp ? 'with' : 'without';
  let score = 0;
  const breakdown = {};

  // A. CORE — Age (using official IRCC table)
  const ageVal = parseInt(d.age)||0;
  // Map select value to actual lookup age
  // value 20 = ages 20-29 (all get same score), value 45 = 45+
  const ageKey = ageVal >= 20 && ageVal <= 29 ? 20 : Math.min(ageVal, 45);
  const agePts = (sp ? CRS_AGE.with : CRS_AGE.without)[ageKey] || 0;
  breakdown.age = agePts; score += agePts;

  // A. CORE — Education
  const eduPts = CRS_EDU[k][d.edu||'none'] || 0;
  breakdown.edu = eduPts; score += eduPts;

  // A. CORE — First official language (4 abilities × per-ability points)
  const l1Levels = [d.l1s, d.l1l, d.l1r, d.l1w];
  const l1Pts = l1Levels.reduce((s,v)=> s + (CRS_LANG1[k][v||'<4']||0), 0);
  breakdown.lang1 = l1Pts; score += l1Pts;

  // A. CORE — Second official language (max 22 with / 24 without)
  const l2Levels = [d.l2s, d.l2l, d.l2r, d.l2w];
  const l2RawPts = l2Levels.reduce((s,v)=> s + (CRS_LANG2[k][v||'<5']||0), 0);
  const l2MaxPts = sp ? 22 : 24;
  const l2Pts = Math.min(l2RawPts, l2MaxPts);
  breakdown.lang2 = l2Pts; score += l2Pts;

  // A. CORE — Canadian work experience
  const canWorkPts = CRS_CANWORK[k][d.canWork||'0'] || 0;
  breakdown.canWork = canWorkPts; score += canWorkPts;

  // B. SPOUSE factors (max 40 total if applicable)
  let spousePts = 0;
  if(sp) {
    const spEduPts  = CRS_SPOUSE_EDU[d.spEdu||'none'] || 0;
    const spL1Pts   = Math.min([d.spl1s,d.spl1l,d.spl1r,d.spl1w].reduce((s,v)=>s+(CRS_SPOUSE_LANG1[v||'<4']||0),0), 20);
    const spWorkPts = CRS_SPOUSE_WORK[d.spWork||'0'] || 0;
    spousePts = Math.min(spEduPts + spL1Pts + spWorkPts, 40);
    breakdown.spouseEdu  = spEduPts;
    breakdown.spouseLang = spL1Pts;
    breakdown.spouseWork = spWorkPts;
    breakdown.spouseTotal= spousePts;
  }
  score += spousePts;

  // C. SKILL TRANSFERABILITY (max 100)
  let skillPts = 0;
  const hasPostSec   = d.edu && !['none','secondary'].includes(d.edu);
  const hasMastersPlus = ['masters','phd'].includes(d.edu||'');
  const has2Plus     = ['two_three','masters','phd'].includes(d.edu||'');
  const l1Min        = Math.min(...l1Levels.map(v=>({' <4':0,'4-5':4.5,'6':6,'7':7,'8':8,'9':9,'10+':10}[v]||0)));
  const l1AllCLB7    = l1Levels.every(v=>['7','8','9','10+'].includes(v));
  const l1AllCLB9    = l1Levels.every(v=>['9','10+'].includes(v));
  const l1Some7Not9  = l1AllCLB7 && !l1AllCLB9;

  // Education + Language
  let eduLangPts = 0;
  if(hasPostSec) {
    if(l1AllCLB9)  eduLangPts = has2Plus||hasMastersPlus ? 50 : 25;
    else if(l1AllCLB7) eduLangPts = has2Plus||hasMastersPlus ? 25 : 13;
  }
  breakdown.skillEduLang = Math.min(eduLangPts,50);

  // Education + Canadian work
  let eduCanPts = 0;
  if(hasPostSec) {
    const cwy = parseInt(d.canWork)||0;
    if(cwy >= 2) eduCanPts = has2Plus||hasMastersPlus ? 50 : 25;
    else if(cwy === 1) eduCanPts = has2Plus||hasMastersPlus ? 25 : 13;
  }
  breakdown.skillEduCan = Math.min(eduCanPts,50);

  // Foreign work + Language
  let fwLangPts = 0;
  const fwy = parseInt(d.foreignWork)||0;
  if(fwy > 0 && l1AllCLB7) {
    if(fwy >= 3) fwLangPts = l1AllCLB9 ? 50 : 25;
    else         fwLangPts = l1AllCLB9 ? 25 : 13;
  }
  breakdown.skillFwLang = Math.min(fwLangPts,50);

  // Foreign work + Canadian work
  let fwCanPts = 0;
  if(fwy > 0) {
    const cwy = parseInt(d.canWork)||0;
    if(fwy >= 3) fwCanPts = cwy >= 2 ? 50 : cwy === 1 ? 25 : 0;
    else         fwCanPts = cwy >= 2 ? 25 : cwy === 1 ? 13 : 0;
  }
  breakdown.skillFwCan = Math.min(fwCanPts,50);

  // Trade certificate + language
  let tradePts = 0;
  if(d.tradeCert) {
    const l1MinCLB = Math.min(...l1Levels.map(v=>({'<4':0,'4-5':4.5,'6':6,'7':7,'8':8,'9':9,'10+':10}[v]||0)));
    if(l1AllCLB7) tradePts = 50;
    else if(l1Levels.every(v=>['4-5','6','7','8','9','10+'].includes(v))) tradePts = 25;
  }
  breakdown.skillTrade = Math.min(tradePts,50);

  skillPts = Math.min(
    breakdown.skillEduLang + breakdown.skillEduCan +
    breakdown.skillFwLang  + breakdown.skillFwCan  + breakdown.skillTrade,
    100
  );
  breakdown.skillTotal = skillPts;
  score += skillPts;

  // D. ADDITIONAL POINTS
  let addPts = 0;
  if(d.sibling) { addPts += 15; breakdown.addSibling = 15; } else { breakdown.addSibling = 0; }

  // French additional points
  const frLevels = [d.fr_s, d.fr_l, d.fr_r, d.fr_w];
  const frAllNCLC7 = frLevels.every(v=>['7','8','9','10+'].includes(v||''));
  let frAddPts = 0;
  if(frAllNCLC7) {
    const engAllCLB5 = l1Levels.every(v=>['5-6','7','8','9','10+'].includes(v||''));
    const engBelowCLB4 = l1Levels.every(v=>['<4','4-5'].includes(v||''));
    if(engAllCLB5) frAddPts = 50;
    else if(engBelowCLB4 || d.noEnglishTest) frAddPts = 25;
    else frAddPts = 25; // CLB5+ meets threshold
  }
  breakdown.addFrench = frAddPts; addPts += frAddPts;

  // Canadian education
  let canEduPts = 0;
  if(d.canEdu === '3yr+') canEduPts = 30;
  else if(d.canEdu === '1-2yr') canEduPts = 15;
  breakdown.addCanEdu = canEduPts; addPts += canEduPts;

  // PNP nomination
  if(d.pnpNomination) { addPts += 600; breakdown.addPNP = 600; } else { breakdown.addPNP = 0; }

  breakdown.addTotal = addPts;
  score += addPts;

  return { total: Math.min(score, 1200), breakdown };
}

// ─────────────────────────────────────────────────────────
// FSW CALCULATOR ENGINE (canada.ca official 100-pt grid)
// Pass mark: 67 points
// ─────────────────────────────────────────────────────────
function calcFSW(d) {
  let score = 0;
  const breakdown = {};

  // Language skills (max 28)
  // First official language — each of 4 abilities: CLB9+=6, CLB8=5, CLB7=4, below CLB7=not eligible
  const fswL1Map = {'7':4,'8':5,'9':6,'10+':6};
  const fswL1Abilities = [d.l1s,d.l1l,d.l1r,d.l1w];
  const fswL1Pts = fswL1Abilities.reduce((s,v)=> s + (fswL1Map[v]||0), 0); // max 24
  // Second language: CLB5+ in all 4 = 4 pts
  const fswL2Levels = [d.l2s,d.l2l,d.l2r,d.l2w];
  const fswL2Eligible = fswL2Levels.every(v=>['5-6','7','8','9','10+'].includes(v||''));
  const fswL2Pts = fswL2Eligible ? 4 : 0; // max 4
  const langTotal = Math.min(fswL1Pts + fswL2Pts, 28);
  breakdown.fswLang = langTotal; score += langTotal;

  // Check minimum: must have CLB7+ in all 4 first-language abilities
  const fswEligible1stLang = fswL1Abilities.every(v=>['7','8','9','10+'].includes(v||''));

  // Education (max 25) — from canada.ca FSW page
  const fswEduMap = {'none':0,'secondary':5,'1yr':15,'2yr':19,'bachelor':21,'two_three':21,'masters':23,'phd':25};
  const eduPts = fswEduMap[d.edu||'none'] || 0;
  breakdown.fswEdu = eduPts; score += eduPts;

  // Work experience (max 15)
  const fswWorkMap = {'0':0,'1':9,'2-3':11,'4-5':13,'6+':15};
  const workPts = fswWorkMap[d.fswWorkExp||'0'] || 0;
  breakdown.fswWork = workPts; score += workPts;

  // Age (max 12)
  const age = parseInt(d.age)||0;
  let agePts = 0;
  if(age >= 18 && age <= 35) agePts = 12;
  else if(age === 36) agePts = 11;
  else if(age === 37) agePts = 10;
  else if(age === 38) agePts = 9;
  else if(age === 39) agePts = 8;
  else if(age === 40) agePts = 7;
  else if(age === 41) agePts = 6;
  else if(age === 42) agePts = 5;
  else if(age === 43) agePts = 4;
  else if(age === 44) agePts = 3;
  else if(age === 45) agePts = 2;
  else if(age === 46) agePts = 1;
  else agePts = 0;
  breakdown.fswAge = agePts; score += agePts;

  // Arranged employment (max 10)
  const aePts = d.fswAE ? 10 : 0;
  breakdown.fswAE = aePts; score += aePts;

  // Adaptability (max 10, combine any)
  let adaptPts = 0;
  if(d.adapt_spouseLang) adaptPts += 5;   // Spouse language CLB4+
  if(d.adapt_ownStudy)   adaptPts += 5;   // Your study in Canada 2+ years
  if(d.adapt_spouseStudy)adaptPts += 5;   // Spouse study in Canada
  if(d.adapt_ownWork)    adaptPts += 10;  // Your past work in Canada 1yr+
  if(d.adapt_spouseWork) adaptPts += 5;   // Spouse past work in Canada
  if(d.adapt_ae)         adaptPts += 5;   // Already got AE points
  if(d.adapt_relatives)  adaptPts += 5;   // Relative in Canada
  adaptPts = Math.min(adaptPts, 10);
  breakdown.fswAdapt = adaptPts; score += adaptPts;

  const total = Math.min(score, 100);
  const eligible = fswEligible1stLang && total >= 67;
  const minLangMet = fswEligible1stLang;

  return { total, breakdown, eligible, minLangMet, passmark: 67 };
}

