function renderProgs(){
  const q=(document.getElementById('p-q')?.value||'').toLowerCase();
  const pv=document.getElementById('p-prov')?.value||'';
  const ty=document.getElementById('p-type')?.value||'';
  const ee=document.getElementById('p-ee')?.value||'';
  const rows=PROGS.filter(p=>{
    if(pv&&p.province!==pv)return false;
    if(ty&&!String(p.type||'').toLowerCase().includes(ty.toLowerCase().split(' ')[0]))return false;
    if(ee==='yes'&&!isYes(p.expressEntry))return false;
    if(ee==='no'&&isYes(p.expressEntry))return false;
    if(q&&!(p.name+p.province+p.type).toLowerCase().includes(q))return false;
    return true;
  });
  const cnt=document.getElementById('p-count');if(cnt)cnt.textContent=`${rows.length} of ${PROGS.length}`;
  const vc=visCols();const em=editMode;
  const thead=document.getElementById('prog-thead');if(!thead)return;
  thead.innerHTML=`<tr>
    ${vc.map(c=>`<th class="${em?'eh':''}" id="th-${c.key}" ${em?`onclick="editColHeader('${c.key}')"`:''}>${c.lbl}${em?'<span style="opacity:.35;font-size:9px;margin-left:3px">✏</span>':''}</th>`).join('')}
    <th style="width:110px">Actions</th>
  </tr>`;
  const tbody=document.getElementById('prog-tbody');if(!tbody)return;
  tbody.innerHTML=rows.length===0
    ?`<tr><td colspan="${vc.length+1}" style="text-align:center;padding:30px;color:#bbb">No programs match the current filters.</td></tr>`
    :rows.map(p=>`<tr>
      ${vc.map(c=>{
        const v=p[c.key]!==undefined?p[c.key]:'';
        let d='';
        if(c.key==='name')d=`<strong style="font-size:12px;cursor:pointer" onclick="openDetail('${p.id}')">${v||'—'}</strong>`;
        else if(c.key==='type')d=`<span class="badge ${tc(v)}">${typeLabel(v)}</span>`;
        else if(c.type==='checkbox'||c.key==='expressEntry'||c.key==='jobOffer')d=isYes(v)?'<span class="badge b-green">Yes</span>':'<span class="badge b-gray">No</span>';
        else if(c.key==='status'){const sc=v==='Open'?'b-green':v==='Paused'?'b-amber':'b-red';d=`<span class="badge ${sc}">${statusLabel(v)}</span>`;}
        else if(c.type==='url'){
          if(v)d=`<span style="display:flex;align-items:center;gap:4px;min-width:0">
            <span style="font-size:11px;color:var(--muted);overflow:hidden;text-overflow:ellipsis;white-space:nowrap;max-width:140px" title="${v}">${v.replace('https://','').replace('http://','').replace('www.','').split('/')[0]}</span>
            <a href="${v}" target="_blank" style="font-size:10px;flex-shrink:0;white-space:nowrap">↗ Open</a>
          </span>`;
          else d='<span style="color:#ddd;font-size:11px">No URL</span>';
        }
        else if(c.type==='number'&&(c.key==='networthMin'||c.key==='investMin'))d=v>0?`$${Number(v).toLocaleString()}`:'—';
        else d=`<span style="font-size:12px">${String(v||'—').substring(0,55)}${String(v||'').length>55?'…':''}</span>`;
        return`<td ${em?`onclick="cellClick(event,'${p.id}','${c.key}')"`:''}>${d}</td>`;
      }).join('')}
      <td><div class="rbtns">
        <button class="rb rb-e" onclick="openDetail('${p.id}')">View</button>
        <button class="rb rb-e" onclick="openEditProg('${p.id}')">✏</button>
        <button class="rb rb-c" onclick="dupProg('${p.id}')">⧉</button>
        <button class="rb rb-d" onclick="confirmDelProg('${p.id}')">✕</button>
