function editColHeader(key){
  if(!editMode)return;
  const th=document.getElementById('th-'+key);if(!th)return;
  const col=COLS.find(c=>c.key===key);if(!col)return;
  const cur=col.lbl;
  th.innerHTML=`<input type="text" value="${cur}" style="border:none;background:#fffde7;font-size:11px;font-weight:700;width:100%;padding:2px 4px;outline:none;min-width:80px">`;
  const inp=th.querySelector('input');inp.focus();inp.select();
  inp.addEventListener('blur',()=>{const v=inp.value.trim()||cur;col.lbl=v;localStorage.setItem(SK.cols,JSON.stringify(COLS));showSaveBar('Column "'+v+'" renamed');renderProgs();});
  inp.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();inp.blur();}if(e.key==='Escape'){col.lbl=cur;renderProgs();}});
