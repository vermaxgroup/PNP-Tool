const THEME_PRESETS = [
  {name:'Navy Blue',    primary:'#1a3f6f', accent:'#1a5fa8', bg:'#f4f4f0', green:'#276221'},
  {name:'Forest Green', primary:'#1a4a2a', accent:'#2e7d52', bg:'#f2f7f2', green:'#1a6b2a'},
  {name:'Burgundy',     primary:'#6b1a2a', accent:'#a0293f', bg:'#faf5f5', green:'#2e6b3a'},
  {name:'Charcoal',     primary:'#2a2a2a', accent:'#4a4a4a', bg:'#f5f5f3', green:'#276221'},
  {name:'Royal Purple', primary:'#3d1a7a', accent:'#6b3fa0', bg:'#f5f2fa', green:'#276221'},
  {name:'Teal',         primary:'#0d5e6e', accent:'#0d9e8e', bg:'#f0f9f8', green:'#276221'},
  {name:'Classic Red',  primary:'#8b1a1a', accent:'#c0392b', bg:'#faf4f4', green:'#276221'},
  {name:'Slate',        primary:'#2c3e50', accent:'#3498db', bg:'#f4f6f8', green:'#27ae60'},
