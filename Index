async function checkAllPrograms(){
  if(!getApiKey()){ toast('⚠ Enter your Anthropic API key first'); return; }
  const toCheck = PROGS.filter(p => p.website).slice(0, 5);
  if(toCheck.length === 0){ toast('No programs with official URLs saved. Add URLs in Edit Mode first.'); return; }
  const resultEl = document.getElementById('live-result');
  resultEl.style.display = 'block';
  resultEl.innerHTML = `<div style="padding:12px;font-size:12px;color:var(--muted)"><span class="spinner"></span> Checking ${toCheck.length} programs — this may take 1–2 minutes…</div>`;
