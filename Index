function openDesignModal(){
  // Load current values
  const d = loadDesign();
  document.getElementById('color-primary').value = d.primary;
  document.getElementById('color-primary-hex').value = d.primary;
  document.getElementById('color-accent').value = d.accent;
  document.getElementById('color-accent-hex').value = d.accent;
  document.getElementById('color-bg').value = d.bg;
  document.getElementById('color-bg-hex').value = d.bg;
  document.getElementById('color-green').value = d.green||'#276221';
  document.getElementById('color-green-hex').value = d.green||'#276221';
  if(d.font) document.getElementById('font-select').value = d.font;
  if(d.navStyle) document.getElementById('nav-style-select').value = d.navStyle;
  if(d.radius) document.getElementById('radius-select').value = d.radius;

  // Build preset swatches
  document.getElementById('theme-presets').innerHTML = THEME_PRESETS.map(t=>`
    <div onclick="applyPreset(${JSON.stringify(t).replace(/"/g,"'")})"
      style="cursor:pointer;border-radius:8px;overflow:hidden;border:2px solid transparent;transition:border-color .15s"
      onmouseover="this.style.borderColor='#aaa'" onmouseout="this.style.borderColor='transparent'">
      <div style="height:28px;background:${t.primary}"></div>
      <div style="height:14px;background:${t.accent}"></div>
      <div style="padding:4px 6px;font-size:10px;font-weight:600;text-align:center;background:#fff;color:#333">${t.name}</div>
    </div>`).join('');

  // Wire up color pickers to sync with hex inputs
  ['primary','accent','bg','green'].forEach(k=>{
    const picker = document.getElementById('color-'+k);
    const hex = document.getElementById('color-'+k+'-hex');
    picker.oninput = ()=>{ hex.value = picker.value; };
    hex.oninput = ()=>{ if(/^#[0-9a-f]{6}$/i.test(hex.value)) picker.value = hex.value; };
  });

  document.getElementById('design-modal').classList.add('open');
}

function applyPreset(t){
  document.getElementById('color-primary').value = t.primary;
  document.getElementById('color-primary-hex').value = t.primary;
  document.getElementById('color-accent').value = t.accent;
  document.getElementById('color-accent-hex').value = t.accent;
  document.getElementById('color-bg').value = t.bg;
  document.getElementById('color-bg-hex').value = t.bg;
  document.getElementById('color-green').value = t.green;
  document.getElementById('color-green-hex').value = t.green;
  applyTheme();
}

function applyTheme(){
  const primary = document.getElementById('color-primary').value;
  const accent  = document.getElementById('color-accent').value;
  const bg      = document.getElementById('color-bg').value;
  const green   = document.getElementById('color-green').value;
  const root = document.documentElement;
  root.style.setProperty('--navy',  primary);
  root.style.setProperty('--blue',  accent);
  root.style.setProperty('--bg',    bg);
  root.style.setProperty('--light', lighten(bg, 0.5));
  root.style.setProperty('--green', green);
  root.style.setProperty('--theme-primary', primary);
  root.style.setProperty('--theme-accent',  accent);
  root.style.setProperty('--theme-bg',      bg);
  toast('✅ Colours applied — click Save Design to keep permanently');
}

function resetTheme(){
  const root = document.documentElement;
  ['--navy','--blue','--bg','--light','--green'].forEach(v=>root.style.removeProperty(v));
  document.getElementById('color-primary').value = '#1a3f6f';
  document.getElementById('color-primary-hex').value = '#1a3f6f';
  document.getElementById('color-accent').value = '#1a5fa8';
  document.getElementById('color-accent-hex').value = '#1a5fa8';
  document.getElementById('color-bg').value = '#f4f4f0';
  document.getElementById('color-bg-hex').value = '#f4f4f0';
  document.getElementById('color-green').value = '#276221';
  document.getElementById('color-green-hex').value = '#276221';
  toast('↺ Colours reset to default');
}

function applyFont(font){
  document.body.style.fontFamily = font;
  toast('Font updated');
}

function applyNavStyle(style){
  const nav = document.getElementById('main-nav');
  if(!nav) return;
  const primary = document.getElementById('color-primary')?.value || '#1a3f6f';
  if(style==='dark'){
    nav.style.background = primary;
    nav.style.borderBottomColor = 'transparent';
    document.querySelectorAll('.nav-tab,.nav-brand-text').forEach(el=>{el.style.color='rgba(255,255,255,0.85)';});
    document.querySelectorAll('.nav-tab.active').forEach(el=>{el.style.color='#fff';el.style.borderBottomColor='#fff';});
  } else if(style==='gradient'){
    nav.style.background = `linear-gradient(135deg, ${primary} 0%, ${lighten(primary,0.3)} 100%)`;
    nav.style.borderBottomColor = 'transparent';
    document.querySelectorAll('.nav-tab,.nav-brand-text').forEach(el=>{el.style.color='rgba(255,255,255,0.85)';});
  } else {
    nav.style.background = '#fff';
    nav.style.borderBottomColor = '';
    document.querySelectorAll('.nav-tab,.nav-brand-text').forEach(el=>{el.style.color='';});
  }
  toast('Nav style updated');
}

function applyRadius(r){
  document.documentElement.style.setProperty('--radius', r);
  // Apply to all buttons and cards
  document.querySelectorAll('.btn,.card,.mc,.metric,.rc,.cc,.pc').forEach(el=>el.style.borderRadius=r);
  toast('Border radius updated');
}

// Simple colour lightening helper
function lighten(hex, amount){
  try{
    const n = parseInt(hex.replace('#',''), 16);
    const r = Math.min(255, ((n>>16)&255) + Math.round(amount*100));
    const g = Math.min(255, ((n>>8)&255)  + Math.round(amount*100));
    const b = Math.min(255,  (n&255)       + Math.round(amount*100));
    return '#'+[r,g,b].map(x=>x.toString(16).padStart(2,'0')).join('');
  }catch{return hex;}
}

function saveDesign(){
  const d = {
    primary: document.getElementById('color-primary')?.value || '#1a3f6f',
    accent:  document.getElementById('color-accent')?.value  || '#1a5fa8',
    bg:      document.getElementById('color-bg')?.value      || '#f4f4f0',
    green:   document.getElementById('color-green')?.value   || '#276221',
    font:    document.getElementById('font-select')?.value   || '',
    navStyle:document.getElementById('nav-style-select')?.value || 'light',
    radius:  document.getElementById('radius-select')?.value || '6px',
  };
  localStorage.setItem(SK_DESIGN, JSON.stringify(d));
  showSaveBar('Design saved — will apply on every load');
  toast('✅ Design saved permanently');
}

function loadDesign(){
  try{return JSON.parse(localStorage.getItem(SK_DESIGN))||{};}catch{return{};}
}

function applyDesignOnLoad(){
  const d = loadDesign();
  if(!d.primary) return; // No saved design
  const root = document.documentElement;
  if(d.primary){ root.style.setProperty('--navy', d.primary); root.style.setProperty('--theme-primary', d.primary); }
  if(d.accent) { root.style.setProperty('--blue', d.accent);  root.style.setProperty('--theme-accent', d.accent); }
  if(d.bg)     { root.style.setProperty('--bg', d.bg);        root.style.setProperty('--light', lighten(d.bg, 0.5)); }
  if(d.green)    root.style.setProperty('--green', d.green);
  if(d.font)     document.body.style.fontFamily = d.font;
  if(d.navStyle) setTimeout(()=>{
    const sel = document.getElementById('nav-style-select');
    if(sel) sel.value = d.navStyle;
    applyNavStyle(d.navStyle);
  }, 100);
  if(d.radius)   applyRadius(d.radius);
}


