      ['p-q','p-prov','p-type','p-ee'].forEach(id=>{
        const el=document.getElementById(id);if(el)el.addEventListener('input',renderProgs);
        if(el&&el.tagName==='SELECT')el.addEventListener('change',renderProgs);
      });
    }
    if(tab.type==='clients'){
      ['c-q','c-sf'].forEach(id=>{
        const el=document.getElementById(id);
        if(el)el.addEventListener(el.tagName==='SELECT'?'change':'input',renderClients);
      });
    }
    if(tab.type==='results'){
      ['r-q','r-cf','r-ef'].forEach(id=>{
        const el=document.getElementById(id);
        if(el)el.addEventListener(el.tagName==='SELECT'?'change':'input',renderResults);
      });
    }
  });
  loadHeadings();
  // Render active tab content
  const activeTab=TABS.find(t=>t.id===_activeTabId)||TABS[0];
  if(activeTab){
    if(activeTab.type==='dashboard')renderDash();
    else if(activeTab.type==='programs'){populateProvDD();renderProgs();}
    else if(activeTab.type==='clients')renderClients();
    else if(activeTab.type==='results')renderResults();
    else if(activeTab.type==='custom_table')renderCustomTable(activeTab);
  }
