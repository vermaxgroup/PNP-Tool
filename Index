function buildProgForm(p){
  // Build cols: website first (after name), then rest
  const baseCols = COLS.filter(c=>c.key!=='website');
  const websiteCol = COLS.find(c=>c.key==='website')||{key:'website',lbl:'Official Website URL',type:'url',show:true,sys:false};
  const extraCols = [
    {key:'jobOfferProvince',lbl:'Job Offer Province',type:'select',show:false,sys:false,
     opts:['','British Columbia','Alberta','Saskatchewan','Manitoba','Ontario','Quebec','Nova Scotia','New Brunswick','Prince Edward Island','Newfoundland and Labrador','Northwest Territories','Yukon']},
    {key:'eeRequired',lbl:'EE Profile Required',type:'select',show:false,sys:false,opts:['Yes','No']},
    {key:'inCanadaRequired',lbl:'Must Be in Canada',type:'select',show:false,sys:false,opts:['Yes','No']},
    {key:'fundsAmt',lbl:'Min Settlement Funds (CAD $)',type:'number'},
    {key:'ownershipPct',lbl:'Ownership % Required',type:'number'},
    {key:'jobsCreate',lbl:'Min Jobs to Create',type:'number'},
    {key:'website2',lbl:'Additional URL / Source 2',type:'url'},
  ];
  const allCols = [websiteCol, ...baseCols, ...extraCols]
    .filter((c,i,arr)=>arr.findIndex(x=>x.key===c.key)===i);

  let html='<div class="fg2">';
  allCols.forEach(c=>{
    const v=p&&p[c.key]!==undefined?p[c.key]:'';
    const wide=['description','criteria','docs','notes'].includes(c.key);
    const isSelect=c.type==='select'&&c.opts;
    html+=`<div class="fg ${wide?'full':''}">`;
    html+=`<label style="display:flex;align-items:center;gap:6px;justify-content:space-between">`;
    html+=`<span>${c.lbl}</span>`;
    if(isSelect){
      html+=`<button type="button" class="rb rb-e" style="font-size:10px;padding:2px 7px;flex-shrink:0" onclick="openDropdownEditorByKey('col',null,'${c.key}')">⚙ Edit Options</button>`;
    }
    if(c.type==='url'&&v){
      html+=`<a href="${v}" target="_blank" style="font-size:10px;padding:2px 6px;background:#e8f0fc;border-radius:4px;color:var(--blue);text-decoration:none;flex-shrink:0">↗ Open</a>`;
    }
    html+=`</label>`;
    if(c.type==='textarea')html+=`<textarea id="pf-${c.key}" rows="${['description','criteria','docs','notes'].includes(c.key)?4:2}">${String(v).replace(/</g,'&lt;')}</textarea>`;
    else if(c.type==='checkbox')html+=`<select id="pf-${c.key}"><option value="Yes" ${v==='Yes'||v===true?'selected':''}>Yes</option><option value="No" ${v!=='Yes'&&v!==true?'selected':''}>No</option></select>`;
    else if(isSelect)html+=`<select id="pf-${c.key}">${c.opts.map(o=>`<option value="${o}" ${o===v?'selected':''}>${o||'— Select —'}</option>`).join('')}</select>`;
    else if(c.type==='number')html+=`<input type="number" id="pf-${c.key}" value="${v||0}" min="0">`;
    else if(c.type==='url')html+=`<input type="url" id="pf-${c.key}" value="${v||''}" placeholder="https://…" style="font-family:monospace;font-size:12px">`;
    else html+=`<input type="text" id="pf-${c.key}" value="${String(v||'').replace(/"/g,'&quot;')}">`;
    html+=`</div>`;
  });
  html+='</div>';return html;
}

function readProgForm(){
  const allCols=[...COLS,
    {key:'jobOfferProvince',type:'text'},{key:'eeRequired',type:'checkbox'},
    {key:'inCanadaRequired',type:'checkbox'},{key:'fundsAmt',type:'number'},
    {key:'ownershipPct',type:'number'},{key:'jobsCreate',type:'number'},{key:'website2',type:'url'},
  ].filter((c,i,arr)=>arr.findIndex(x=>x.key===c.key)===i);
  const d={};
  allCols.forEach(c=>{const el=document.getElementById('pf-'+c.key);if(!el)return;let v=el.value;if(c.type==='number')v=parseFloat(v)||0;d[c.key]=v;});
