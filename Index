  showConfirm(`Delete tab "${tab.lbl}"?`,'All data in this tab will be permanently deleted.',()=>{
    TABS=TABS.filter(t=>t.id!==tabId);
    saveAll('Tab deleted');
    const firstTab=TABS[0];
    renderTabs();
    if(firstTab)showTab(firstTab.id);
