function forceDeleteTab(tabId){
  // Allows removing even built-in tabs (they stay in TABS with removed:true so they can be restored)
  const tab=TABS.find(t=>t.id===tabId);if(!tab)return;
  showConfirm(`Remove "${tab.lbl}" tab?`,'The tab will be hidden from the nav. Click "Restore Defaults" in Manage Tabs to bring it back. No data is deleted.',()=>{
    tab.visible=false;tab._removed=true;
    saveAll('Tab removed');closeM('table-modal');renderNavTabs();
    const first=TABS.find(t=>t.visible!==false&&!t._removed);
    if(first)showTab(first.id);
    toast(`Tab "${tab.lbl}" removed — restore it from ⚙ Manage Tabs`);
  });
}
function restoreDefaultTabs(){
  // Show all hidden/removed tabs and ensure all defaults exist
  TABS.forEach(t=>{ t.visible=true; delete t._removed; });
  DEFAULT_TABS.forEach(dt=>{ if(!TABS.find(t=>t.id===dt.id)) TABS.push(JSON.parse(JSON.stringify(dt))); });
  saveAll('Tabs restored');openManageFeatures();renderNavTabs();toast('✅ All tabs restored');
}

