// ── calcCRSDirect — same as calcCRS but accepts pre-calculated french add pts ──
function calcCRSDirect(d, frAddPts){
  const sp = d.hasSpouse;
  const k  = sp ? 'with' : 'without';
  let score = 0; const breakdown = {};
  // Age
  const ageVal = parseInt(d.age)||0;
  const ageKey = ageVal >= 20 && ageVal <= 29 ? 20 : Math.min(ageVal, 45);
  breakdown.age = (sp ? CRS_AGE.with : CRS_AGE.without)[ageKey] || 0;
  score += breakdown.age;
  // Education
  breakdown.edu = CRS_EDU[k][d.edu||'none'] || 0;
  score += breakdown.edu;
  // First language
  const l1 = [d.l1s,d.l1l,d.l1r,d.l1w];
  breakdown.lang1 = l1.reduce((s,v)=>s+(CRS_LANG1[k][v||'none']||0),0);
  score += breakdown.lang1;
  // Second language
  const l2MaxPts = sp ? 22 : 24;
  breakdown.lang2 = Math.min([d.l2s,d.l2l,d.l2r,d.l2w].reduce((s,v)=>s+(CRS_LANG2[k][v||'none']||0),0), l2MaxPts);
  score += breakdown.lang2;
  // Canadian work
  breakdown.canWork = CRS_CANWORK[k][d.canWork||'0']||0;
  score += breakdown.canWork;
  // Spouse factors
  let spousePts = 0;
  if(sp){
    breakdown.spouseEdu  = CRS_SPOUSE_EDU[d.spEdu||'none']||0;
    breakdown.spouseLang = Math.min([d.spl1s,d.spl1l,d.spl1r,d.spl1w].reduce((s,v)=>s+(CRS_SPOUSE_LANG1[v||'none']||0),0), 20);
    breakdown.spouseWork = CRS_SPOUSE_WORK[d.spWork||'0']||0;
    breakdown.spouseTotal = Math.min(breakdown.spouseEdu+breakdown.spouseLang+breakdown.spouseWork, 40);
    spousePts = breakdown.spouseTotal;
  }
  score += spousePts;
  // Skill transferability
  const hasPostSec = !['none','secondary'].includes(d.edu||'');
  const has2Plus   = ['two_three','masters','phd'].includes(d.edu||'');
  const l1AllCLB7  = l1.every(v=>['7','8','9','10+'].includes(v));
  const l1AllCLB9  = l1.every(v=>['9','10+'].includes(v));
  const cwy = parseInt(d.canWork)||0;
  const fwy = parseInt(d.foreignWork)||0;
  let eduLangPts=0,eduCanPts=0,fwLangPts=0,fwCanPts=0,tradePts=0;
  if(hasPostSec){
    if(l1AllCLB9)  eduLangPts=has2Plus?50:25; else if(l1AllCLB7) eduLangPts=has2Plus?25:13;
    if(cwy>=2) eduCanPts=has2Plus?50:25; else if(cwy===1) eduCanPts=has2Plus?25:13;
  }
  if(fwy>0&&l1AllCLB7){ if(fwy>=3) fwLangPts=l1AllCLB9?50:25; else fwLangPts=l1AllCLB9?25:13; }
  if(fwy>0){ if(fwy>=3) fwCanPts=cwy>=2?50:cwy===1?25:0; else fwCanPts=cwy>=2?25:cwy===1?13:0; }
  if(d.tradeCert){ if(l1AllCLB7) tradePts=50; else if(l1.every(v=>['4-5','6','7','8','9','10+'].includes(v))) tradePts=25; }
  breakdown.skillEduLang=Math.min(eduLangPts,50); breakdown.skillEduCan=Math.min(eduCanPts,50);
  breakdown.skillFwLang=Math.min(fwLangPts,50);   breakdown.skillFwCan=Math.min(fwCanPts,50);
  breakdown.skillTrade=Math.min(tradePts,50);
  breakdown.skillTotal=Math.min(eduLangPts+eduCanPts+fwLangPts+fwCanPts+tradePts, 100);
  score += breakdown.skillTotal;
  // Additional
  breakdown.addSibling = d.sibling?15:0;     score += breakdown.addSibling;
  breakdown.addFrench  = frAddPts||0;        score += breakdown.addFrench;
  breakdown.addCanEdu  = d.canEdu==='3yr+'?30:d.canEdu==='1-2yr'?15:0; score += breakdown.addCanEdu;
  breakdown.addPNP     = d.pnpNomination?600:0; score += breakdown.addPNP;
  return { total:Math.min(score,1200), breakdown };
}

function saveCRSResult(){
  const d = getCRSData();
  const frAdd = d.frenchAdd === '25' ? 25 : d.frenchAdd === '50' ? 50 : 0;
  const result = calcCRSDirect(d, frAdd);
  // Custom extra fields
  loadCalcFields();
  let extraPts = 0;
  (CALC_EXTRA_FIELDS.crs||[]).forEach(f=>{
    const el = document.getElementById('cef-crs-'+f.id);
    if(!el) return;
    const pts = parseInt(f.pts)||0;
    if(f.type==='select' && el.value) extraPts += pts;
    else if(f.type==='number' && el.value && !isNaN(+el.value) && +el.value>0) extraPts += pts;
    else if(f.type!=='select' && f.type!=='number' && el.value && el.value.trim()) extraPts += pts;
  });
  const total = Math.min(result.total + extraPts, 1200);
  const name   = document.getElementById('calc-client-name')?.value.trim() || 'Unnamed';
  const linkId = document.getElementById('calc-link-client')?.value || '';
  const notes  = document.getElementById('calc-notes')?.value || '';
  const rec = {
    id: 'score_'+Date.now(), type:'crs', name, linkedClientId:linkId,
    date: new Date().toLocaleDateString('en-CA'),
    crsTotal: total,
    crsBreakdown: {...result.breakdown, extraPts},
    crsInputs: d,
    notes, sources:'canada.ca CRS criteria (2025-08-21)',
    eligible: total >= 400 ? 'Competitive' : total >= 300 ? 'Moderate' : 'Low',
    lastEdited: new Date().toISOString()
  };
  CALC_SCORES.push(rec);
  saveCalcScores();
  toast('✅ CRS score '+total+' saved for "'+name+'"');
  showSaveBar('CRS score saved');
}
function saveFSWResult(){
  loadCalcCfg();
  const d = getFSWData();
  const cfg = CALC_CFG?.fsw;
  const ageOpts  = cfg?.ageOpts  || getDefaultCalcCfg().fsw.ageOpts;
  const eduOpts  = cfg?.eduOpts  || getDefaultCalcCfg().fsw.eduOpts;
  const workOpts = cfg?.workOpts || getDefaultCalcCfg().fsw.workOpts;

  const fswL1Map = {'7':4,'8':5,'9':6,'10+':6,'below7':0,'':0};
  const l1Pts = ['s','l','r','w'].reduce((s,a)=>s+(fswL1Map[d['l1'+a]]||0),0);
  const l2AllCLB5 = ['s','l','r','w'].every(a=>d['l2'+a]==='clb5+');
  const langTotal = Math.min(l1Pts+(l2AllCLB5?4:0), 28);

  const eduOpt  = eduOpts.find(o=>o.value===(document.getElementById('fsw-edu')?.value||'none'))||{pts:0};
  const workOpt = workOpts.find(o=>o.value===(document.getElementById('fsw-work')?.value||'0'))||{pts:0};
  const ageOpt  = ageOpts.find(o=>o.value===(d.fswAgeVal||'0'))||{pts:0};

  const eduPts  = eduOpt.pts||0;
  const workPts = workOpt.pts||0;
  const agePts  = ageOpt.pts||0;
  const aePts   = d.fswAE?10:0;

  let adaptPts=0;
  if(d.adapt_spouseLang) adaptPts+=5;
  if(d.adapt_ownStudy)   adaptPts+=5;
  if(d.adapt_spouseStudy)adaptPts+=5;
  if(d.adapt_ownWork)    adaptPts+=10;
  if(d.adapt_spouseWork) adaptPts+=5;
  if(d.adapt_ae)         adaptPts+=5;
  if(d.adapt_relatives)  adaptPts+=5;
  adaptPts = Math.min(adaptPts,10);

  // Custom extra fields
  loadCalcFields();
  let extraPts=0;
  (CALC_EXTRA_FIELDS.fsw||[]).forEach(f=>{
    const el=document.getElementById('cef-fsw-'+f.id);
    if(!el) return;
    const pts=parseInt(f.pts)||0;
    if(f.type==='select'&&el.value) extraPts+=pts;
    else if(f.type==='number'&&el.value&&!isNaN(+el.value)&&+el.value>0) extraPts+=pts;
    else if(f.type!=='select'&&f.type!=='number'&&el.value&&el.value.trim()) extraPts+=pts;
  });

  const baseTotal = langTotal+eduPts+workPts+agePts+aePts+adaptPts;
  const total = Math.min(baseTotal+extraPts, 200);
  const fswL1MinCLB7 = ['s','l','r','w'].every(a=>['7','8','9','10+'].includes(d['l1'+a]||''));
  const eligible = fswL1MinCLB7 && total >= 67;

  const name    = document.getElementById('fsw-client-name')?.value.trim()||'Unnamed';
  const linkId  = document.getElementById('fsw-link-client')?.value||'';
  const notes   = document.getElementById('fsw-notes')?.value||'';
  const rec = {
    id:'score_'+Date.now(), type:'fsw', name, linkedClientId:linkId,
    date: new Date().toLocaleDateString('en-CA'),
    fswTotal: total,
    fswBreakdown: {langTotal, eduPts, workPts, agePts, aePts, adaptPts, extraPts},
    fswInputs: d,
    notes, sources:'canada.ca FSW six selection factors (reviewed 2026-03-09)',
    eligible: eligible?'Eligible':'Not Eligible',
    minLangMet: fswL1MinCLB7,
    lastEdited: new Date().toISOString()
  };
  CALC_SCORES.push(rec);
  saveCalcScores();
  toast('✅ FSW score '+total+' saved for "'+name+'" — '+(eligible?'ELIGIBLE':'NOT ELIGIBLE'));
  showSaveBar('FSW score saved');
}
