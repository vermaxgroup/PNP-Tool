function toggleCol(key,v){const c=COLS.find(x=>x.key===key);if(c){c.show=v;localStorage.setItem(SK.cols,JSON.stringify(COLS));renderProgs();}}
function renameCol(key,v){const c=COLS.find(x=>x.key===key);if(c&&v.trim()){c.lbl=v.trim();localStorage.setItem(SK.cols,JSON.stringify(COLS));showSaveBar('Column renamed');}}
function removeCol(key){const c=COLS.find(x=>x.key===key);if(c?.sys){toast('Cannot remove system columns');return;}COLS=COLS.filter(x=>x.key!==key);PROGS.forEach(p=>delete p[key]);saveAll('Column removed');openColMgr();renderProgs();}
function addCustomCol(){
  const lbl = (document.getElementById('new-col-lbl')?.value||'').trim();
  const type = document.getElementById('new-col-type')?.value||'text';
  if(!lbl){ toast('⚠ Enter a column label first'); document.getElementById('new-col-lbl')?.focus(); return; }
  const key = 'cx_'+lbl.toLowerCase().replace(/[^a-z0-9]/g,'_').slice(0,20)+'_'+Date.now().toString().slice(-4);
  const newCol = {key, lbl, type, show:true, sys:false};
  if(type==='select') newCol.opts = ['Option 1','Option 2','Option 3'];
