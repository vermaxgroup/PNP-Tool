let _apiKey = '';
function saveApiKey(){
  const inp = document.getElementById('api-key-input');
  const key = (inp?.value||'').trim();
  if(!key || !key.startsWith('sk-ant')){
    document.getElementById('apikey-status').innerHTML = '<span style="color:var(--red)">⚠ That does not look like a valid Anthropic API key. Keys start with "sk-ant-".</span>';
    return;
  }
  _apiKey = key;
  sessionStorage.setItem('cnpnp_apikey', key);
  document.getElementById('apikey-status').innerHTML = '<span style="color:var(--green)">✅ Key saved for this session.</span>';
  document.getElementById('live-apikey-section').style.display = 'none';
  document.getElementById('live-check-section').style.display = 'block';
  // Populate the program select
  const sel = document.getElementById('live-prog-select');
  sel.innerHTML = '<option value="">— Select a program —</option>';
  PROGS.forEach(p => { const o = document.createElement('option'); o.value = p.id; o.textContent = p.name + ' (' + p.province + ')'; sel.appendChild(o); });
}
function toggleApiKeyVisibility(){
  const inp = document.getElementById('api-key-input');
  inp.type = inp.type === 'password' ? 'text' : 'password';
}
function getApiKey(){
  if(_apiKey) return _apiKey;
  const stored = sessionStorage.getItem('cnpnp_apikey');
  if(stored){ _apiKey = stored; return stored; }
  return null;
}

