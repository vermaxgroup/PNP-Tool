// ── UPDATE CRS (reads CALC_CFG + CALC_EXTRA_FIELDS) ──
function updateCRS(){
  const d = getCRSData();
  const spSection = document.getElementById('crs-spouse-section');
  if(spSection) spSection.style.display = d.hasSpouse ? 'block' : 'none';
  const frAdd = document.getElementById('crs-french-add')?.value;
  const frAddPts = frAdd==='25'?25:frAdd==='50'?50:0;
  // Custom extra fields
  loadCalcFields();
  let extraPts = 0;
  (CALC_EXTRA_FIELDS.crs||[]).forEach(f=>{
    const el=document.getElementById('cef-crs-'+f.id);
    if(!el) return;
    const pts=parseInt(f.pts)||0;
    if(f.type==='select'&&el.value&&el.value!='') extraPts+=pts;
    else if(f.type==='number'&&el.value&&!isNaN(+el.value)&&+el.value>0) extraPts+=pts;
    else if(f.type!=='select'&&f.type!=='number'&&el.value&&el.value.trim()) extraPts+=pts;
  });
  const result = calcCRSDirect(d, frAddPts);
  const total = Math.min(result.total + extraPts, 1200);
  const totalEl = document.getElementById('crs-total');
  if(totalEl) totalEl.textContent = total;
  const bkEl = document.getElementById('crs-breakdown');
  if(bkEl){
    const b=result.breakdown;
    const sp=d.hasSpouse;
    const row=(label,pts,max)=>
      `<div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f5f5f0">
        <span style="color:${pts>0?'var(--text)':'#bbb'}">${label}</span>
        <span style="font-weight:700;color:${pts>0?'var(--navy)':'#ccc'}">${pts}<span style="font-size:10px;color:#bbb"> /${max}</span></span>
      </div>`;
    bkEl.innerHTML=
      `<div style="font-size:10px;font-weight:700;text-transform:uppercase;color:#aaa;margin-bottom:6px">Breakdown</div>`+
      row('Age', b.age, sp?100:110)+row('Education', b.edu, sp?140:150)+
      row('Language 1', b.lang1, sp?128:136)+row('Language 2', b.lang2, sp?22:24)+
      row('Canadian Work', b.canWork, sp?70:80)+
      (sp?row('Spouse Factors', b.spouseTotal||0, 40):'')+
      row('Skill Transferability', b.skillTotal, 100)+
      row('Sibling in Canada', b.addSibling||0, 15)+
      row('French Additional', frAddPts, 50)+
      row('Canadian Education', b.addCanEdu||0, 30)+
      row('PNP Nomination', b.addPNP||0, 600)+
      (extraPts>0?row('Custom Fields', extraPts, '—'):'')+
      `<div style="display:flex;justify-content:space-between;padding:6px 0;font-weight:800;font-size:14px;border-top:2px solid var(--border);margin-top:4px">
        <span>TOTAL</span><span style="color:var(--navy)">${total}</span>
      </div>`;
  }
}

// ── UPDATE FSW (reads CALC_CFG + CALC_EXTRA_FIELDS) ──
function updateFSW(){
  loadCalcCfg();
  const cfg = CALC_CFG?.fsw;
  const ageOpts  = cfg?.ageOpts  || getDefaultCalcCfg().fsw.ageOpts;
  const eduOpts  = cfg?.eduOpts  || getDefaultCalcCfg().fsw.eduOpts;
  const workOpts = cfg?.workOpts || getDefaultCalcCfg().fsw.workOpts;

  const d = getFSWData();
  // Language
  const fswL1Map = {'7':4,'8':5,'9':6,'10+':6,'below7':0,'':0};
  const l1Pts = ['s','l','r','w'].reduce((s,a)=>s+(fswL1Map[d['l1'+a]]||0),0);
  const l2AllCLB5 = ['s','l','r','w'].every(a=>d['l2'+a]==='clb5+');
  const l2Pts = l2AllCLB5?4:0;
  const langTotal = Math.min(l1Pts+l2Pts, 28);

  // Education — lookup from editable table
  const ageVal = document.getElementById('fsw-age')?.value||'0';
  const ageOpt = ageOpts.find(o=>o.value===ageVal)||{pts:0};
  const agePts = ageOpt.pts||0;

  const eduVal = document.getElementById('fsw-edu')?.value||'none';
  const eduOpt = eduOpts.find(o=>o.value===eduVal)||{pts:0};
  const eduPts = eduOpt.pts||0;

  const workVal = document.getElementById('fsw-work')?.value||'0';
  const workOpt = workOpts.find(o=>o.value===workVal)||{pts:0};
  const workPts = workOpt.pts||0;

  const aePts = document.getElementById('fsw-ae')?.checked?10:0;

  let adaptPts=0;
  if(document.getElementById('fsw-adapt-spl')?.checked)    adaptPts+=5;
  if(document.getElementById('fsw-adapt-ownstudy')?.checked)adaptPts+=5;
  if(document.getElementById('fsw-adapt-spstudy')?.checked) adaptPts+=5;
  if(document.getElementById('fsw-adapt-ownwork')?.checked) adaptPts+=10;
  if(document.getElementById('fsw-adapt-spwork')?.checked)  adaptPts+=5;
  if(document.getElementById('fsw-adapt-ae')?.checked)      adaptPts+=5;
  if(document.getElementById('fsw-adapt-rel')?.checked)     adaptPts+=5;
  adaptPts=Math.min(adaptPts,10);

  // Custom extra fields
  loadCalcFields();
  let extraPts=0;
  (CALC_EXTRA_FIELDS.fsw||[]).forEach(f=>{
    const el=document.getElementById('cef-fsw-'+f.id);
    if(!el) return;
    const pts=parseInt(f.pts)||0;
    if(f.type==='select'&&el.value&&el.value!='') extraPts+=pts;
    else if(f.type==='number'&&el.value&&!isNaN(+el.value)&&+el.value>0) extraPts+=pts;
    else if(f.type!=='select'&&f.type!=='number'&&el.value&&el.value.trim()) extraPts+=pts;
  });

  const baseTotal = Math.min(langTotal+eduPts+workPts+agePts+aePts+adaptPts, 100);
  const total = Math.min(baseTotal+extraPts, 200); // allow overflow for custom fields
  const passmark = 67;
  const fswL1MinCLB7 = ['s','l','r','w'].every(a=>['7','8','9','10+'].includes(d['l1'+a]||''));
  const eligible = fswL1MinCLB7 && total >= passmark;

  const totalEl = document.getElementById('fsw-total');
  if(totalEl){ totalEl.textContent=total; totalEl.style.color=eligible?'var(--green)':total>=60?'#e67e22':'var(--red)'; }

  const eligEl = document.getElementById('fsw-eligibility');
  if(eligEl){
    if(!fswL1MinCLB7) eligEl.innerHTML=`<div style="background:#fce8e6;border-radius:6px;padding:8px 10px;font-size:12px;color:var(--red);font-weight:700">⚠ Language minimum not met — CLB 7+ required in all 4 abilities</div>`;
    else if(eligible) eligEl.innerHTML=`<div style="background:#e6f4ea;border-radius:6px;padding:8px 10px;font-size:13px;color:var(--green);font-weight:700;text-align:center">✅ ELIGIBLE — Score ≥ ${passmark}</div>`;
    else eligEl.innerHTML=`<div style="background:#fce8e6;border-radius:6px;padding:8px 10px;font-size:13px;color:var(--red);font-weight:700;text-align:center">✗ NOT ELIGIBLE — Need ${passmark-total} more pts</div>`;
  }

  const bkEl = document.getElementById('fsw-breakdown');
  if(bkEl){
    const row=(l,p,m)=>`<div style="display:flex;justify-content:space-between;padding:4px 0;border-bottom:1px solid #f5f5f0"><span style="color:${p>0?'inherit':'#bbb'}">${l}</span><span style="font-weight:700;color:${p>0?'var(--navy)':'#ccc'}">${p}<span style="font-size:10px;color:#bbb"> /${m}</span></span></div>`;
    bkEl.innerHTML=
      row('Language Skills',langTotal,28)+row('Education',eduPts,25)+
      row('Work Experience',workPts,15)+row('Age',agePts,12)+
      row('Arranged Employment',aePts,10)+row('Adaptability',adaptPts,10)+
      (extraPts>0?row('Custom Fields',extraPts,'—'):'')+
      `<div style="display:flex;justify-content:space-between;padding:6px 0;font-weight:800;font-size:14px;border-top:2px solid var(--border);margin-top:4px"><span>TOTAL</span><span style="color:${eligible?'var(--green)':'var(--red)'}">${total} / ${passmark} pass</span></div>`;
  }
}

