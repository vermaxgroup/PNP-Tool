// KEY-BASED lookup — avoids passing data through onclick attribute strings
function openDropdownEditorByKey(type, ref, key){
  let opts=[], label='';
  if(type==='col'){
    const c=COLS.find(x=>x.key===key);
    if(!c){toast('⚠ Column not found: '+key);return;}
    opts=[...(c.opts||[])];label=c.lbl;
  }else if(type==='clientfield'){
    const f=BASE_CLIENT_FIELDS.find(x=>x.key===key)||CLIENT_EXTRA_FIELDS.find(x=>x.key===key);
    if(!f){toast('⚠ Field not found: '+key);return;}
    opts=[...(f.opts||[])];label=f.lbl;
  }else if(type==='customtablecol'){
    const tab=TABS.find(t=>t.id===ref);
    const c=tab?.cols?.find(x=>x.key===key);
    if(!c){toast('⚠ Column not found');return;}
    opts=[...(c.opts||[])];label=c.lbl;
  }
  openDropdownEditor(type,ref,key,opts,label);
}

function openColMgr(){
  let html='';
  COLS.forEach(c=>{
    const isSelect=c.type==='select';
    html+=`<div class="field-row">
      <input type="checkbox" ${c.show?'checked':''} onchange="toggleCol('${c.key}',this.checked)">
      ${c.sys?`<span style="flex:1;font-weight:600;font-size:12px">${esc(c.lbl)}</span>`:`<input type="text" value="${esc(c.lbl)}" onchange="renameCol('${c.key}',this.value)" style="flex:1;border:1px solid #eee;border-radius:4px;padding:3px 7px;font-size:12px">`}
      <span style="font-size:10px;color:#aaa;min-width:50px">${c.type}</span>
      ${isSelect?`<button class="rb rb-e" onclick="openDropdownEditorByKey('col',null,'${c.key}')">⚙ Options</button>`:''}
      ${!c.sys?`<button class="rb rb-d" onclick="removeCol('${c.key}')">✕</button>`:'<span style="font-size:10px;color:#bbb">🔒</span>'}
    </div>`;
  });
  document.getElementById('col-list').innerHTML=html;
