function editInline(idOrEl){
  const el=typeof idOrEl==='string'?document.querySelector(`[data-heading="${idOrEl}"]`)||document.getElementById(idOrEl):idOrEl;
  if(!el||el.contentEditable==='true')return;
  el.contentEditable='true';el.focus();
  const range=document.createRange();range.selectNodeContents(el);
  const sel=window.getSelection();sel.removeAllRanges();sel.addRange(range);
  const done=()=>{el.contentEditable='false';saveHeadings();showSaveBar('Heading updated');};
  el.addEventListener('blur',done,{once:true});
  el.addEventListener('keydown',e=>{if(e.key==='Enter'){e.preventDefault();el.blur();}});
}
function toggleEdit(){
  editMode=!editMode;
  document.getElementById('etoggle').classList.toggle('on',editMode);
  document.getElementById('edot').style.background=editMode?'var(--amber)':'#ccc';
  document.getElementById('elbl').textContent=editMode?'Edit Mode ON':'Edit Mode';
  document.getElementById('ebanner').classList.toggle('on',editMode);
  // Show/hide Page Text button
  document.querySelectorAll('.edit-mode-only').forEach(el=>el.style.display=editMode?'':'none');
  renderNavTabs();
  const tab=TABS.find(t=>t.id===_activeTabId)||TABS[0];
  if(tab){
    if(tab.type==='dashboard')renderDash();
    else if(tab.type==='programs'){populateProvDD();renderProgs();}
    else if(tab.type==='clients')renderClients();
    else if(tab.type==='results')renderResults();
    else if(tab.type==='custom_table')renderCustomTable(tab);
    else if(tab.type==='crs')renderCRS();
    else if(tab.type==='fsw')renderFSW();
    else if(tab.type==='scores')renderSavedScores();
    else if(tab.type==='compare')renderCompare();
    else if(tab.type==='notes'){
      const noteEl=document.getElementById('notes-content-'+tab.id);
      if(noteEl)noteEl.contentEditable=editMode?'true':'false';
    }
  }
  setTimeout(applyHiddenHeadings, 30);
  if(editMode)toast('✏️ Turn on 📝 Page Text to edit, hide or delete any heading');
}

// Render ONLY the nav tab bar (fast — no view rebuild)
function renderNavTabs(){
  const container=document.getElementById('nav-tabs');
  container.innerHTML='';
  TABS.filter(tab=>tab.visible!==false&&!tab._removed).forEach(tab=>{
    const div=document.createElement('div');
    div.className='nav-tab'+(tab.id===_activeTabId?' active':'');
    div.dataset.tabid=tab.id;
    div.innerHTML=`<span class="tlbl" data-heading="tab_${tab.id}">${tab.lbl}</span>`;
    div.addEventListener('click',e=>{
      if(editMode&&e.target.classList.contains('tlbl')){editTabLabel(div.querySelector('.tlbl'));return;}
      showTab(tab.id);
    });
    container.appendChild(div);
  });
  if(editMode){
    const add=document.createElement('div');
    add.className='nav-tab';
    add.innerHTML='<span style="color:var(--green);font-weight:700">+ Tab</span>';
    add.onclick=()=>openAddTab();
    container.appendChild(add);
    // Manage Tabs button in edit mode
    const mgr=document.createElement('div');
    mgr.className='nav-tab';
    mgr.innerHTML='<span style="color:var(--amber);font-weight:600">⚙ Tabs</span>';
    mgr.onclick=()=>openManageFeatures();
    container.appendChild(mgr);
  }
  // Restore headings from storage
  const h=JSON.parse(localStorage.getItem(SK.headings)||'{}');
  Object.entries(h).forEach(([k,v])=>{const el=document.querySelector(`[data-heading="${k}"]`);if(el&&v&&el.textContent!==v)el.textContent=v;});
}

function showTab(tabId){
  _activeTabId=tabId;
  // Update nav highlight
  document.querySelectorAll('.nav-tab').forEach(el=>el.classList.remove('active'));
  const activeNav=document.querySelector(`[data-tabid="${tabId}"]`);
  if(activeNav)activeNav.classList.add('active');
  // Switch view visibility
  document.querySelectorAll('.view').forEach(el=>el.classList.remove('active'));
  const view=document.getElementById('view-'+tabId);
  if(view)view.classList.add('active');
  // Re-render the active view content
  const tab=TABS.find(t=>t.id===tabId);
  if(!tab)return;
  if(tab.type==='dashboard')renderDash();
  else if(tab.type==='programs'){populateProvDD();renderProgs();}
  else if(tab.type==='clients')renderClients();
  else if(tab.type==='results')renderResults();
  else if(tab.type==='custom_table')renderCustomTable(tab);
}
function closeM(id){document.getElementById(id).classList.remove('open');}
function dtab(b,p){
  document.querySelectorAll('#view-dashboard .tabb, #view-'+_activeTabId+' .tabb').forEach(x=>x.classList.remove('on'));
  document.querySelectorAll('#view-dashboard .tabp, #view-'+_activeTabId+' .tabp').forEach(x=>x.classList.remove('on'));
  b.classList.add('on');document.getElementById(p)?.classList.add('on');
}

