    </div>`).join('') +
    `<div style="margin-top:10px;font-size:11px;color:var(--muted)">Click individual programs to see full details.</div>`;
  saveAll('Update log saved'); renderUpdateLog();
}
function buildCheckPrompt(prog){
  const today = new Date().toLocaleDateString('en-CA');
  return `You are a Canadian immigration data analyst. Today's date is ${today}.

Check the CURRENT requirements for this Provincial Nominee Program by visiting its official government website and compare to my stored data.

Program: ${prog.name}
Province: ${prog.province}
Official Website: ${prog.website || 'Search for the official provincial government page for this program'}

MY STORED DATA (may be outdated):
- Min CLB: ${prog.clb || 'not stored'}
- Min Work Experience: ${prog.expYears || 0} years
- TEER Levels: ${prog.teerText || 'not stored'}
- Job Offer Required: ${prog.jobOffer ? 'Yes' : 'No'}
- Application Fee: ${prog.fees || 'not stored'}
- Processing Time: ${prog.processing || 'not stored'}
- Program Status: ${prog.status || 'not stored'}
- Last Verified: ${prog.lastVerified || 'never'}
- Description: ${(prog.description || '').substring(0, 200)}
- Eligibility Criteria: ${(prog.criteria || '').substring(0, 300)}

INSTRUCTIONS:
1. Visit the official website URL above (or search for the official provincial government page)
2. Extract ALL current requirements as of today (${today})
3. Compare carefully to my stored data
4. Respond in EXACTLY this format:

STATUS: [CHANGED / NO CHANGES / UNABLE TO VERIFY]
DATE CHECKED: ${today}

CURRENT REQUIREMENTS (from official site):
- Min CLB: [current]
- Min Work Experience: [current]
- TEER Levels: [current]
- Job Offer Required: [Yes/No]
- Application Fee: [current]
- Processing Time: [current]
- Program Status: [Open/Paused/Closed/Intake-Limited]

CHANGES FROM YOUR STORED DATA:
[List each specific change, or "None detected"]

RECOMMENDED UPDATES FOR YOUR DATABASE:
[Exact field-by-field updates to make, or "No updates needed"]

OFFICIAL SOURCE VERIFIED: [exact URL checked]`;
}
async function checkProgram(prog){
  const resultEl = document.getElementById('live-result');
  resultEl.style.display = 'block';
  resultEl.innerHTML = `<div style="padding:12px;font-size:12px;color:var(--muted)"><span class="spinner"></span> Checking <strong>${prog.name}</strong> against official sources…</div>`;
  await callClaudeForUpdate(buildCheckPrompt(prog), prog.name, prog.id);
}
async function checkProgramSilently(prog){
  try{
    const key = getApiKey();
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514', max_tokens: 800,
        tools: [{type: 'web_search_20250305', name: 'web_search'}],
        messages: [{role: 'user', content: buildCheckPrompt(prog)}]
      })
    });
    const data = await resp.json();
    let text = ''; if(data.content) data.content.forEach(b => { if(b.type === 'text') text += b.text; });
    const status = text.includes('STATUS: CHANGED') ? 'CHANGED' : text.includes('STATUS: NO CHANGES') ? 'OK' : 'UNKNOWN';
    return {program: prog.name, status, text};
  } catch(e) { return {program: prog.name, status: 'ERROR', text: e.message}; }
}
async function callClaudeForUpdate(prompt, progName, progId){
  const resultEl = document.getElementById('live-result');
  const key = getApiKey();
  if(!key){
    resultEl.innerHTML = `<div class="wrn">No API key found. Please enter your Anthropic API key above to use Live Update.</div>`;
    return;
  }
  try{
    const resp = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': key,
        'anthropic-version': '2023-06-01',
        'anthropic-dangerous-direct-browser-access': 'true'
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514', max_tokens: 1200,
        tools: [{type: 'web_search_20250305', name: 'web_search'}],
        messages: [{role: 'user', content: prompt}]
      })
    });
    const data = await resp.json();
    const today = new Date().toLocaleDateString('en-CA');
    let text = '';
    if(data.error){
      const errMsg = data.error.message || 'Unknown error';
      resultEl.innerHTML = `<div class="wrn" style="white-space:pre-wrap"><strong>API Error:</strong> ${errMsg}<br><br><strong>Common fixes:</strong><br>• Make sure you copied the full API key (starts with sk-ant-api03-…)<br>• Check your key is active at console.anthropic.com<br>• Ensure your account has credits available</div>`;
      logUpdate(progName, 'ERROR');
      return;
    }
    if(data.content) data.content.forEach(b => { if(b.type === 'text') text += b.text; });
    const status = text.includes('STATUS: CHANGED') ? 'CHANGED' : text.includes('STATUS: NO CHANGES') ? 'OK' : 'UNKNOWN';
    logUpdate(progName, status);
    if(progId){
      const prog = PROGS.find(p => p.id === progId);
      if(prog) prog.lastVerified = today;
    }
    saveAll('Update log saved');
    resultEl.innerHTML = `
      <div style="display:flex;align-items:center;gap:8px;margin-bottom:10px;flex-wrap:wrap">
        <span class="badge ${status==='CHANGED'?'b-red':status==='OK'?'b-green':'b-gray'}" style="font-size:12px;padding:4px 10px">${status==='CHANGED'?'⚠ Changes Found':status==='OK'?'✓ No Changes':'? Unknown'}</span>
        <span style="font-size:12px;color:var(--muted)">Checked: ${today}</span>
      </div>
      <div style="background:var(--bg);border-radius:7px;padding:14px;font-size:13px;line-height:1.8;white-space:pre-wrap;max-height:380px;overflow-y:auto;border:1px solid var(--border)">${text || 'No response received.'}</div>
      ${status==='CHANGED'?`<div class="wrn" style="margin-top:10px">⚠️ Changes detected! Click "Edit Program" below to update your database with the new information.</div>`:''}
      ${progId?`<div style="margin-top:10px;display:flex;gap:8px"><button class="btn btn-amber btn-sm" onclick="closeM('live-modal');openEditProg('${progId}')">✏ Edit Program</button><button class="btn btn-sec btn-sm" onclick="document.getElementById('live-result').style.display='none'">Clear</button></div>`:''}`;
    renderUpdateLog();
  } catch(e){
    resultEl.innerHTML = `<div class="wrn"><strong>Connection error:</strong> ${e.message}<br><br>Check your internet connection and try again.</div>`;
    logUpdate(progName, 'ERROR');
  }
}
function logUpdate(program, status){
  UPDATE_LOG.push({date: new Date().toLocaleDateString('en-CA'), program, status});
  if(UPDATE_LOG.length > 100) UPDATE_LOG = UPDATE_LOG.slice(-100);
}

